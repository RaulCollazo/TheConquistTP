Object subclass: #Jugador	instanceVariableNames: 'Nombre Tema'	classVariableNames: ''	package: 'TheConquist'!Object subclass: #TableroLogico	instanceVariableNames: ''	classVariableNames: ''	package: 'TheConquist'!Object subclass: #Juego	instanceVariableNames: 'CantNPC CantJugadores PantallaActual imagenMorph'	classVariableNames: ''	package: 'TheConquist'!!Juego methodsFor: 'as yet unclassified' stamp: '1/22/2025 05:28'!eliminarMorphsWorld submorphs "Selecciona a todos los submorphs y descide si es un ImageMorph para eliminarlo"        select: [ :morph | morph isKindOf: ImageMorph ]        thenDo: [ :morph | morph delete ].! !!Juego methodsFor: 'as yet unclassified' stamp: '1/22/2025 05:27'!dibujarFondo    | imagen  boton1 boton2 |        "Cargar la imagen de fondo"    imagen := Form fromFileNamed: FileSystem workingDirectory / 'assets/backgrounds/background.png'.        "Crear ImageMorph para la imagen de fondo"    imagenMorph := ImageMorph new.    imagenMorph image: imagen.    imagenMorph position: 0@0. "Asegurarse de que la imagen de fondo esté en la esquina superior izquierda"        "Crear el botón 1"    boton1 := SimpleButtonMorph new.    boton1 label: 'Nuevo Juego'. "Definir el texto del botón"    boton1 target: self. "Definir el objetivo de la acción como la instancia actual"    boton1 actionSelector: #obtenerCantJugadores. "Definir el método a llamar cuando se presiona el botón"        "Posicionar el botón 1 en el centro de la imagen"    boton1 position: (imagenMorph width // 2 - (boton1 width // 2)) @ (imagenMorph height // 2 - (boton1 height // 2) - 30).    "Crear el botón 2"    boton2 := SimpleButtonMorph new.    boton2 label: 'Salir'. "Definir el texto del botón"    boton2 target: self. "Definir el objetivo de la acción como la instancia actual"    boton2 actionSelector: #eliminarMorphs. "Definir el método a llamar cuando se presiona el botón"        "Posicionar el botón 2 debajo del botón 1"    boton2 position: (imagenMorph width // 2 - (boton2 width // 2)) @ (imagenMorph height // 2 - (boton2 height // 2) + 30).        "Agregar los botones al ImageMorph"    imagenMorph addMorph: boton1.    imagenMorph addMorph: boton2.        "Abrir el ImageMorph en el mundo"    imagenMorph openInWorld.! !!Juego methodsFor: 'as yet unclassified' stamp: '1/21/2025 22:43'!nuevoJuegoTranscript show: ['Nuevo juego'].! !!Juego methodsFor: 'as yet unclassified' stamp: '1/22/2025 05:26'!obtenerCantJugadores    | flag|    flag := false.    "Solicitar la cantidad de NPCs"    [ flag not ] whileTrue: [        CantNPC := (UIManager default request: '¿Cuántos participantes hay?') asNumber.        ((CantNPC sqrt \\ 2) = 0)            ifTrue: [ flag := true ]            ifFalse: [ UIManager default inform: 'Valor inválido' ].    ].    "Solicitar la cantidad de jugadores humanos"    CantJugadores := (UIManager default request: '¿Cuántos participantes humanos habrá?') asNumber.! !!Juego methodsFor: 'accessing' stamp: '1/21/2025 19:35'!cantNPC	^ CantNPC! !!Juego methodsFor: 'accessing' stamp: '1/21/2025 19:35'!cantNPC: anObject	CantNPC := anObject! !!Juego methodsFor: 'accessing' stamp: '1/21/2025 19:35'!cantJugadores	^ CantJugadores! !!Juego methodsFor: 'accessing' stamp: '1/21/2025 19:35'!cantJugadores: anObject	CantJugadores := anObject! !!Juego methodsFor: 'accessing' stamp: '1/21/2025 19:35'!pantallaActual	^ PantallaActual! !!Juego methodsFor: 'accessing' stamp: '1/21/2025 19:35'!pantallaActual: anObject	PantallaActual := anObject! !!Juego methodsFor: 'accessing' stamp: '1/21/2025 21:41'!imagenMorph	^ imagenMorph! !!Juego methodsFor: 'accessing' stamp: '1/21/2025 21:41'!imagenMorph: anObject	imagenMorph := anObject! !!Juego methodsFor: 'initialization' stamp: '1/21/2025 19:36'!initializePantallaActual := 0.! !"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!Juego class	instanceVariableNames: ''!!Juego class methodsFor: 'as yet unclassified' stamp: '1/22/2025 05:39'!iniciar| instancia |instancia := self new. "Crea una instancia de Juego"^ instancia dibujarFondo. "Llama al método obtenerCantJug y devuelve su resultado"! !Object subclass: #Casilla	instanceVariableNames: 'morph'	classVariableNames: ''	package: 'TheConquist'!!Casilla methodsFor: 'as yet unclassified' stamp: '1/21/2025 16:53'!crearCasilla: x and: y    "Crear un Morph cuadrado y almacenarlo en la variable de instancia"    morph := Morph new.    morph color: Color blue.    morph extent: 100@100. "Tamaño del cuadrado (100x100 píxeles)"    morph position: x@y. "Posicionar el morph según las coordenadas pasadas"    World addMorph: morph.! !!Casilla methodsFor: 'as yet unclassified' stamp: '1/21/2025 16:54'!eliminarCasilla    "Eliminar el Morph del mundo si existe"    morph ifNotNil: [        morph delete.        morph := nil.    ].! !