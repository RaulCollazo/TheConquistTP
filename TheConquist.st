jugadorActual tema ifTrue: [				(tmp5 = tmp3 and: (1 < tmp4 and: tmp4 < tmp2)) ifTrue: [					tmp1						add: tmp4 - 1 @ tmp3;						add: tmp4 + 1 @ tmp3;						add: tmp4 @ (tmp3 - 1) ] ].			(TableroLogico matrizDeTemas at: tmp4 column: tmp5)			= jugadorActual tema ifTrue: [				((1 < tmp4 and: tmp4 < tmp2) and: (1 < tmp5 and: tmp5 < tmp3))					ifTrue: [						tmp1							add: tmp4 - 1 @ tmp5;							add: tmp4 + 1 @ tmp5;							add: tmp4 @ (tmp5 - 1);							add: tmp4 @ (tmp5 + 1) ] ] ] ].	1.	tmp1 := tmp1 atRandom.	tmp7 := tmp1 x.	tmp8 := tmp1 y.	tmp6 := TableroLogico matrizTableroLógico at: tmp7 column: tmp8.	tmp6 nPC		ifTrue: [			Transcript show: 'Duelo de bot - persona'.			tmp9 := Random new next < 0.5.			tmp9				ifTrue: [ self ganaDesafiante: jugadorActual desafiado: tmp6 ]				ifFalse: [ self ganaDesafiante: tmp6 desafiado: jugadorActual ] ]		ifFalse: [ Transcript show: 'Duelo de bots' ].self flujoPrincipalTableroYaCreado .! !!Juego methodsFor: 'ManageJuego' stamp: '2/14/2025 00:53'!jugadorPersonaActivaUIManager default confirm: 'Hola'.self flujoPrincipalTableroYaCreado.! !!Juego methodsFor: 'removing' stamp: '2/9/2025 03:14'!removeButtonMorphs    "Elimina todos los ButtonMorphs de la variable de instancia imagenMorph"    imagenMorph := nil.! !!Juego methodsFor: 'removing' stamp: '2/9/2025 03:43'!removeAllMorphsFromImageMorphExceptBackground    "Elimina todos los morphs añadidos a imagenMorph excepto el background"    imagenMorph submorphs do: [:each |         (each isKindOf: ImageMorph) ifFalse: [ imagenMorph removeMorph: each ]    ].! !!Juego methodsFor: 'Accesorios' stamp: '2/14/2025 00:53'!esJugadorBot(self jugadorActual nPC) ifTrue: [ self simularDuelo ] ifFalse: [self jugadorPersonaActiva.].! !!Juego methodsFor: 'Accesorios' stamp: '2/9/2025 02:10'!obtenerJugadorActualself jugadorActual: (TableroLogico obtenerJugadorTurnoActual: self cantNPC).self class jugadordelTurnoActualClase: self jugadorActual.UIManage