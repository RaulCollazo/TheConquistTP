| archivo contenido personas primeraPersona nombre edad ciudad |"Ruta del archivo JSON"archivo := FileSystem workingDirectory / 'assets/txt.json'."Leer el contenido del archivo como texto"contenido := archivo readStream contents."Convertir el JSON a una colección Pharo (Array)"personas := NeoJSONReader fromString: contenido."Acceder al primer elemento del arreglo (primera persona)"primeraPersona := personas first.nombre := primeraPersona at: 'nombre'. "Devuelve 'Alice'"edad := primeraPersona at: 'edad'. "Devuelve 28"ciudad := primeraPersona at: 'ciudad'. "Devuelve 'Barcelona'""Imprimir los valores de la primera persona"Transcript show: 'Primera persona: '; cr.Transcript show: 'Nombre: ', nombre; cr.Transcript show: 'Edad: ', edad asString; cr.Transcript show: 'Ciudad: ', ciudad; cr."Iterar sobre todas las personas e imprimir su información"Transcript show: 'Lista de personas:'; cr.personas do: [ :persona |    Transcript show: 'Nombre: ', (persona at: 'nombre'); cr.    Transcript show: 'Edad: ', ((persona at: 'edad') asString); cr.    Transcript show: 'Ciudad: ', (persona at: 'ciudad'); cr; cr.].