	#tags : {
		#timestamp : DateAndTime [ '2025-01-23T06:53:39.854-03:00' ],
		#self : OmReference [ '5' ]
	},
	#content : '"Test de la clase Matriz"\r| matriz testPassed |\r\rTranscript clear.\r\r"1. Crear una matriz 3x3"\rmatriz := Matriz rows: 3 columns: 3.\r\r"2. Asignar valores a la matriz"\rmatriz atRow: 1 column: 1 put: 5.\rmatriz atRow: 1 column: 2 put: 10.\rmatriz atRow: 1 column: 3 put: 15.\rmatriz atRow: 2 column: 1 put: 20.\rmatriz atRow: 2 column: 2 put: 25.\rmatriz atRow: 2 column: 3 put: 30.\rmatriz atRow: 3 column: 1 put: 35.\rmatriz atRow: 3 column: 2 put: 40.\rmatriz atRow: 3 column: 3 put: 45.\r\r"3. Verificar los valores asignados"\rtestPassed := true.\rtestPassed := testPassed & (matriz atRow: 1 column: 1 = 5).\rtestPassed := testPassed & (matriz atRow: 1 column: 2 = 10).\rtestPassed := testPassed & (matriz atRow: 1 column: 3 = 15).\rtestPassed := testPassed & (matriz atRow: 2 column: 1 = 20).\rtestPassed := testPassed & (matriz atRow: 2 column: 2 = 25).\rtestPassed := testPassed & (matriz atRow: 2 column: 3 = 30).\rtestPassed := testPassed & (matriz atRow: 3 column: 1 = 35).\rtestPassed := testPassed & (matriz atRow: 3 column: 2 = 40).\rtestPassed := testPassed & (matriz atRow: 3 column: 3 = 45).\r\r"4. Imprimir la matriz"\rTranscript show: \'Matriz creada e inicializada:\'; cr.\rmatriz printMatrix.\r\r"5. Mostrar resultado del test"\rtestPassed\r    ifTrue: [ Transcript show: \'Todos los tests pasaron correctamente.\'; cr ]\r    ifFalse: [ Transcript show: \'Error en los tests.\'; cr ].\r'
}OmEntry {
