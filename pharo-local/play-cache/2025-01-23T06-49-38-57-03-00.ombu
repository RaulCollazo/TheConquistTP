	},
	#content : '| matrix text elements |\rtext := \'Historia|Geografía|Literatura|Arte|Ciencia|Filosofía|Música|Cine|Deportes|Tecnología|Política|Economía|Medicina|Psicología|Religión|Astronomía|Mitología|Medio ambiente|Matemáticas|Lenguas|Sociología|Antropología|Economía global|Arquitectura|Innovaciones tecnológicas|Historia del arte|Educación|Grandes civilizaciones|Derechos humanos|Cultura pop|Poesía|Biografías de personajes históricos|Exploración espacial|Literatura clásica|Filosofía oriental|Literatura contemporánea|Expresiones artísticas|Sociología urbana|Fotografía|Historia de la música|Moda|Historia de la moda|Cultura asiática|Cultura latina|Cultura europea|Historia de la guerra|Política internacional|Movimientos sociales|Cultura digital|Historia del cine|Derechos animales|Psicología del comportamiento|Historia de la ciencia|Filosofía política|Desarrollo sostenible|Tendencias tecnológicas|Literatura feminista|Arquitectura moderna|Historia de la tecnología|Literatura infantil|Grandes inventos|Juegos tradicionales|Filosofía occidental|Estilos musicales|Culturas indígenas|Arte contemporáneo|Filosofía moderna|Música clásica|Historia de las religiones|Historia de la economía|Revoluciones sociales\'.\relements := text substrings: \'|\'.\r\r"Crear una matriz 8x8"\rmatrix := Matrix rows: 8 columns: 8.\r\r"Recorrer los elementos y asignarlos a la matriz"\r1 to: elements size do: [:i |\r    | row col |\r    row := (i - 1) // 8 + 1.\r    col := (i - 1) \\\\ 8 + 1.\r    matrix at: row column: col put: (elements at: i).\r].\r\r"Imprimir la matriz para verificar"\rmatrix rows do: [:rowIndex |\r    1 to: matrix cols do: [:colIndex |\r        Transcript show: (matrix at: rowIndex column: colIndex); space.\r    ].\r    Transcript cr.\r].\r'
}OmEntry {
