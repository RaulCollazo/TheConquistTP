	#content : EpMethodModification {
		#oldMethod : RGMethodDefinition {
			#annotations : IdentityDictionary {
				#className : #Juego,
				#isMeta : false
			},
			#name : #obtenerCantJugadores,
			#protocol : #'as yet unclassified',
			#sourceCode : 'obtenerCantJugadores\r    | flag MatrizTemas|\r    flag := false.\r    "Solicitar la cantidad de NPCs"\r    [ flag not ] whileTrue: [\r        CantNPC := (UIManager default request: \'¿Cuántos participantes hay?\') asNumber.\r        ((CantNPC sqrt isInteger)) \r            ifTrue: [ flag := true ]\r            ifFalse: [ UIManager default inform: \'Valor inválido\' ].\r    ].\r\r    "Solicitar la cantidad de jugadores humanos"\r    CantJugadores := (UIManager default request: \'¿Cuántos participantes humanos habrá?\') asNumber.\r\rTableroLogico crearMatrizTemas: CantJugadores.\rMatrizTemas := TableroLogico matrizdeTemas.\rMatrizTemas inspect.\r\rself dibujarFondoTablero .',
			#stamp : '1/25/2025 21:59',
			#package : #TheConquist
		},
		#newMethod : RGMethodDefinition {
			#annotations : IdentityDictionary {
				#className : #Juego,
				#isMeta : false
			},
			#name : #obtenerCantJugadores,
			#protocol : #'as yet unclassified',
			#sourceCode : 'obtenerCantJugadores\r    | flag MatrizTemas cantNPCInput|\r    flag := false.\r    \r    "Solicitar la cantidad de NPCs"\r    [ flag not ] whileTrue: [\r        cantNPCInput := UIManager default request: \'¿Cuántos participantes hay?\'.\r        CantNPC := cantNPCInput asNumber.\r        ((CantNPC isInteger) and: [CantNPC > 0]) "Asegurarse de que CantNPC es un número entero positivo"\r            ifTrue: [ \r                ((CantNPC sqrt isInteger) and: [CantNPC sqrt asInteger squared = CantNPC]) "Verificar si la raíz cuadrada es un entero"\r                    ifTrue: [ flag := true ]\r                    ifFalse: [ UIManager default inform: \'El número debe tener una raíz cuadrada exacta\' ].\r            ]\r            ifFalse: [ UIManager default inform: \'Valor inválido, por favor ingrese un número entero positivo\' ].\r    ].\r\r    "Solicitar la cantidad de jugadores humanos"\r    CantJugadores := (UIManager default request: \'¿Cuántos participantes humanos habrá?\') asNumber.\r\r    TableroLogico crearMatrizTemas: CantJugadores.\r    MatrizTemas := TableroLogico matrizdeTemas.\r    MatrizTemas inspect.\r\r    self dibujarFondoTablero .',
			#stamp : '1/25/2025 22:01',
			#package : #TheConquist
		}
	}
}OmEntry {
	#tags : {
		#prior : OmReference [ '84' ],
		#self : OmReference [ '85' ]
	},
	#content : EpMethodModification {
		#oldMethod : RGMethodDefinition {
			#annotations : IdentityDictionary {
				#className : #'TableroLogico class',
				#isMeta : true
			},
			#name : #'crearMatrizTemas:',
			#protocol : #'creaciónDeMatrices',
			#sourceCode : 'crearMatrizTemas: cantJugadores\r| file contents elements matrix matrixSize |\r"Abre el archivo y lee su contenido"\rfile := FileSystem workingDirectory / \'assets\' / \'temas.txt\'.\rcontents := file readStreamDo: [ :stream | stream contents ].\r"Divide el contenido del archivo en elementos usando \'|\' como delimitador"\relements := contents substrings: \'|\'.\relements := elements shuffled.\r"Crear la matriz"\rmatrixSize := cantJugadores sqrt.\rmatrix := Matrix rows: matrixSize columns: matrixSize.\r\r"Recorrer los elementos y asignarlos a la matriz"\r1 to: (matrixSize * matrixSize) do: [:i |\r    | row col |\r    row := (i - 1) // matrixSize + 1.  "Calcula la fila"\r    col := (i - 1) \\\\ matrixSize + 1.   "Calcula la columna"\r    (i <= elements size) ifTrue: [\r        matrix at: row column: col put: (elements at: i).\r    ] ifFalse: [\r        matrix at: row column: col put: nil. "O algún valor por defecto"\r    ].\r].\rmatrix inspect.\rMatrizdeTemas := matrix.',
			#stamp : '1/25/2025 21:39',
			#package : #TheConquist
		},
		#newMethod : RGMethodDefinition {
			#annotations : IdentityDictionary {
				#className : #'TableroLogico class',
				#isMeta : true
			},
			#name : #'crearMatrizTemas:',
			#protocol : #'creaciónDeMatrices',
			#sourceCode : 'crearMatrizTemas: cantJugadores\r    | file contents elements matrix matrixSize |\r    "Abre el archivo y lee su contenido"\r    file := FileSystem workingDirectory / \'assets\' / \'temas.txt\'.\r    contents := file readStreamDo: [ :stream | stream contents ].\r    "Divide el contenido del archivo en elementos usando \'|\' como delimitador"\r    elements := contents substrings: \'|\'.\r    elements := elements shuffled.\r    "Crear la matriz"\r    matrixSize := cantJugadores sqrt.\r    "Verificar que matrixSize sea un entero positivo"\r    (matrixSize isInteger and: [matrixSize > 0]) ifFalse: [^ self error: \'El tamaño de la matriz debe ser un entero positivo\'].\r    matrix := Matrix rows: matrixSize columns: matrixSize.\r\r    "Recorrer los elementos y asignarlos a la matriz"\r    1 to: (matrixSize * matrixSize) do: [:i |\r        | row col |\r        row := (i - 1) // matrixSize + 1.  "Calcula la fila"\r        col := (i - 1) \\\\ matrixSize + 1.   "Calcula la columna"\r        (i <= elements size) ifTrue: [\r            matrix at: row column: col put: (elements at: i).\r        ] ifFalse: [\r            matrix at: row column: col put: nil. "O algún valor por defecto"\r        ].\r    ].\r    matrix inspect.\r    MatrizdeTemas := matrix.',
			#stamp : '1/25/2025 22:03',
			#package : #TheConquist
		}
	}
}