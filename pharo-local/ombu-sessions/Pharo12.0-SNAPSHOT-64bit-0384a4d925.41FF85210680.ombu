			#sourceCode : 'crearMatrizTablero: cantJugadores NPCs: cantNPCs\r|matrizTablero fila columna jugador cantNPClocal random booleanValue file contents elements|\rfile := FileSystem workingDirectory / \'assets\' / \'nombresNPC.txt\'.\rcontents := file readStreamDo: [ :stream | stream contents ].\r"Divide el contenido del archivo en elementos usando \'|\' como delimitador"\relements := contents substrings: \'|\'.\rfila := 1.\rcolumna := 1.\rrandom := Random new.\rcantNPClocal := cantNPCs.\r"La matriz tablero va a estar compuesta por el objeto jugadores, que contendrá en cada posición los datos del jugador, si es NPC o no, su tema y sus puntos"\rjugador := Jugador new.\rmatrizTablero := Matrix rows: (cantJugadores sqrt) columns: (cantJugadores sqrt).\r\r1 to: cantJugadores  do: [\r\t(cantNPClocal = 0) ifFalse:[   \r\t(booleanValue := random next < 0.2) ifTrue: [ \r\t\t(cantNPClocal := cantNPClocal - 1).\r\t\t(jugador nombre: (UIManager default request: \'Por favor ingrese el nombre del participante\')).\r\t\t(jugador nPC: false).\r\t\t(jugador puntosProbabilidad: 0).\r\t\t(jugador tema: (self matrizdeTemas at: fila column:columna)).\r\t\t[ (fila = cantJugadores sqrt) ifTrue: [ fila := 0. columna := columna + 1]].\r\t\t(fila := fila + 1)\r\t\t ]\r\t ifFalse: [ \r\t\t(jugador nombre: (elements atRandom)).\r\t\t(jugador nPC: true).\r\t\t(jugador puntosProbabilidad: 0).\r\t\t(jugador tema: (self matrizdeTemas at: fila column:columna)).\r\t\t[ (fila = cantJugadores sqrt) ifTrue: [ fila := 0. columna := columna + 1]].\r\t\t(fila := fila + 1)\r\t\t ].\t\r\t ] ifTrue: [ \r\t\t(jugador nombre: (elements atRandom)).\r\t\t(jugador nPC: true).\r\t\t(jugador puntosProbabilidad: 0).\r\t\t(jugador tema: (self matrizdeTemas at: fila column:columna)).\r\t\t[ (fila = cantJugadores sqrt) ifTrue: [ fila := 0. columna := columna + 1]].\r\t\t(fila := fila + 1)]\r].\r\rmatrizTablero inspect.\r',
			#stamp : '1/25/2025 21:36',
