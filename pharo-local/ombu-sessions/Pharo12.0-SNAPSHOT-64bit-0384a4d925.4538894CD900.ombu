	#tags : {
		#prior : OmReference [ '7' ],
		#self : OmReference [ '8' ]
	},
	#content : EpMethodAddition {
		#method : RGMethodDefinition {
			#annotations : IdentityDictionary {
				#className : #'TableroLogico class',
				#isMeta : true
			},
			#name : #dibujarTablero,
			#protocol : #'as yet unclassified',
			#sourceCode : 'dibujarTablero\r|Casilla fila columna|\rfila := 0.\rcolumna := 1.\r1 to: (Juego cantNPC) do:\r[:i|\r\tfila := fila + 1.\r\tCasilla := TableroLogico matrizDeMorphs at: fila column: columna.\r\t(fila = (Juego cantNPC sqrt)) ifTrue: [fila := 1. columna := columna + 1].\r\tJuego imagenMorph addMorph: Casilla.\r\tCasilla position: (10*i)@(10*i).\r\t]',
			#stamp : '1/31/2025 21:23',
			#package : #TheConquist
		}
	}
}OmEntry {
