	#content : EpMethodModification {
		#oldMethod : RGMethodDefinition {
			#annotations : IdentityDictionary {
				#className : #'TableroLogico class',
				#isMeta : true
			},
			#name : #'dibujarTablero:cantNPC:',
			#protocol : #'as yet unclassified',
			#sourceCode : 'dibujarTablero: imagenMorph cantNPC: cantNPC\r| temaCasilla fila columna |\rfila := 1.\rcolumna := 1.\r1 to: cantNPC do: [:i |\r    temaCasilla := TableroLogico matrizDeMorphs at: fila column: columna.\r    imagenMorph addMorph: temaCasilla.\r    temaCasilla position: (columna * 100) @ (fila * 100). "Ajusta la posición según sea necesario"\r\r    fila := fila + 1.\r    (fila > (cantNPC sqrt) ceiling) ifTrue: [\r        fila := 1.\r        columna := columna + 1.\r    ].\r]',
			#stamp : '1/31/2025 21:38',
			#package : #TheConquist
		},
		#newMethod : RGMethodDefinition {
			#annotations : IdentityDictionary {
				#className : #'TableroLogico class',
				#isMeta : true
			},
			#name : #'dibujarTablero:cantNPC:',
			#protocol : #'as yet unclassified',
			#sourceCode : 'dibujarTablero: imagenMorph cantNPC: cantNPC\r| temaCasilla fila columna spacing morphSize |\rfila := 1.\rcolumna := 1.\rspacing := 10. "Espacio entre los morphs"\rmorphSize := 50. "Tamaño de cada morph"\r1 to: cantNPC do: [:i |\r    "Obtener el morph correspondiente de la matriz de morphs"\r    temaCasilla := TableroLogico matrizDeMorphs at: fila column: columna.\r    \r    "Agregar el morph al imagenMorph"\r    imagenMorph addMorph: temaCasilla.\r    \r    "Calcular la posición del morph"\r    temaCasilla position: ((columna - 1) * (morphSize + spacing)) @ ((fila - 1) * (morphSize + spacing)).\r    \r    "Aumentar la fila"\r    fila := fila + 1.\r    \r    "Si la fila excede el límite, reiniciar fila y aumentar columna"\r    (fila > (cantNPC sqrt) ceiling) ifTrue: [\r        fila := 1.\r        columna := columna + 1.\r    ].\r]',
			#stamp : '1/31/2025 21:39',
			#package : #TheConquist
		}
	}
}OmEntry {
