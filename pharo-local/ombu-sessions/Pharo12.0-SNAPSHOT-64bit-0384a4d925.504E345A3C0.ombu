			#sourceCode : 'verificarContinuidad\r    | fila columna primer |\r    primer := (TableroLogico matrizTableroLógico at: 1 column: 1).\r    fila := 1.\r    columna := 1.\r\r    1 to: self cantNPC do: [ :i |\r        (fila > self cantNPC sqrt ceiling) ifTrue: [ \r            fila := 1. \r            columna := columna + 1.\r        ].\r\r        ((TableroLogico matrizTableroLógico at: fila column: columna) ~= primer) ifTrue: [ \r            ^ false. "Sale inmediatamente si encuentra diferencia"\r        ].\r\r        fila := fila + 1.\r    ].\r\r    ^ true. "Si no encontró diferencias, retorna true"',
