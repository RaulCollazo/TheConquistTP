	#tags : {
		#prior : OmReference [ '6' ],
		#self : OmReference [ '7' ]
	},
	#content : EpMethodAddition {
		#method : RGMethodDefinition {
			#annotations : IdentityDictionary {
				#className : #Juego,
				#isMeta : false
			},
			#name : #verificarContinuidad,
			#protocol : #'as yet unclassified',
			#sourceCode : 'verificarContinuidad\r|fila columna nombre flag|\rnombre := TableroLogico matrizTableroLógico at: 1 column: 1 nombre.\rflag := false.\rfila := 1.\rcolumna := 1.\r1 to: self cantNPC do: [  \r\t(fila > self cantNPC sqrt ceiling) ifTrue: [ fila := 1. columna := columna +1 ].\r((TableroLogico matrizTableroLógico at: fila column: columna) nombre  ~=  nombre) ifTrue: [^ flag := true. ].\rfila := fila + 1.].\r^flag.',
			#stamp : '2/14/2025 02:00',
			#package : #TheConquist
		}
	}
}OmEntry {
