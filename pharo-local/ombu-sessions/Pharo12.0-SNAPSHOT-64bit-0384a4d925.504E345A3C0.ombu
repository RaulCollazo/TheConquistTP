	#tags : {
		#prior : OmReference [ '28' ],
		#self : OmReference [ '29' ]
	},
	#content : EpMethodAddition {
		#method : RGMethodDefinition {
			#annotations : IdentityDictionary {
				#className : #Juego,
				#isMeta : false
			},
			#name : #verificarContinuidad,
			#protocol : #'as yet unclassified',
			#sourceCode : 'verificarContinuidad\r    | fila columna primer nombreDiferente encontrado |\r    primer := (TableroLogico matrizTableroLógico at: 1 column: 1) nombre.\r    fila := 1.\r    columna := 1.\r    encontrado := false.\r\r    1 to: self cantNPC do: [ :i |\r        (fila > self cantNPC sqrt ceiling) ifTrue: [ \r            fila := 1. \r            columna := columna + 1.\r        ].\r        \r        nombreDiferente := (TableroLogico matrizTableroLógico at: fila column: columna) nombre.\r        \r        (nombreDiferente ~= primer) ifTrue: [ \r            encontrado := true.\r        ].\r\r        fila := fila + 1.\r    ].\r\r    ^ encontrado. "Retorna true si encontró al menos un nombre diferente, de lo contrario false"',
			#stamp : '2/14/2025 02:26',
			#package : #TheConquist
		}
	}
}OmEntry {
