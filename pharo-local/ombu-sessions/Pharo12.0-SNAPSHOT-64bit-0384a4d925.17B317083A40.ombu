			#sourceCode : 'crearMatrizTablero: cantJugadores NPCs: cantNPCs\r    | matrizTablero fila columna random cantNPClocal nombreJugador jugador file contents elements |\r\r    (cantJugadores sqrt isInteger) ifFalse: [ \r        self error: \'La cantidad de jugadores debe ser un cuadrado perfecto.\' \r    ].\r    (cantNPCs > cantJugadores) ifTrue: [ \r        self error: \'La cantidad de NPCs no puede ser mayor a la de jugadores.\' \r    ].\r\r    file := FileSystem workingDirectory / \'assets\' / \'nombresNPC.txt\'.\r    contents := file readStreamDo: [ :stream | stream contents ].\r    elements := contents substrings: \'|\'.\r\r    elements isEmpty ifTrue: [\r        self error: \'El archivo de nombresNPC.txt está vacío o no contiene datos válidos.\'\r    ].\r\r    fila := 1.\r    columna := 1.\r    random := Random new.\r    cantNPClocal := cantNPCs.\r    matrizTablero := Matrix rows: (cantJugadores sqrt) columns: (cantJugadores sqrt).\r\r    1 to: cantJugadores do: [\r        jugador := Jugador new.\r\r        (cantNPClocal > 0 and: (random next < 0.2)) ifTrue: [\r            cantNPClocal := cantNPClocal - 1.\r            nombreJugador := UIManager default request: \'Por favor ingrese el nombre del participante\'.\r            (nombreJugador isEmptyOrNil) ifTrue: [\r                self error: \'Debe ingresar un nombre válido para continuar.\'\r            ].\r            jugador nombre: nombreJugador.\r            jugador nPC: false.\r        ] ifFalse: [\r            jugador nombre: (elements atRandom).\r            jugador nPC: true.\r        ].\r\r        jugador puntosProbabilidad: 0.\r\r        (self matrizDeTemas isNil or: [fila > (self matrizDeTemas rows) or: [columna > (self matrizDeTemas cols)]]) ifTrue: [\r            self error: \'Índices de matrizDeTemas fuera de rango\'\r        ].\r        jugador tema: (self matrizDeTemas at: fila column: columna).\r\r        (fila > matrizTablero rows or: [columna > matrizTablero cols]) ifTrue: [\r            self error: \'Índices de matrizTablero fuera de rango\'\r        ].\r        matrizTablero at: fila column: columna put: jugador.\r\r        fila := fila + 1.\r        (fila > cantJugadores sqrt) ifTrue: [\r            fila := 1.\r            columna := columna + 1.\r        ].\r    ].\r\r    matrizTablero inspect.\r',
