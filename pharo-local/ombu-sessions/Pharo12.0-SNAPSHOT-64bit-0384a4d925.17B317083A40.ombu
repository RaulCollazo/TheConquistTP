			#sourceCode : 'crearMatrizTablero: cantJugadores NPCs: cantNPCs\r| matrizTablero fila columna random cantNPClocal nombreJugador jugador file contents elements |\r(cantJugadores sqrt isInteger) ifFalse: [ \r    self error: \'La cantidad de jugadores debe ser un cuadrado perfecto.\' \r].\r(cantNPCs > cantJugadores) ifTrue: [ \r    self error: \'La cantidad de NPCs no puede ser mayor a la de jugadores.\' \r].\r\rfile := FileSystem workingDirectory / \'assets\' / \'nombresNPC.txt\'.\rcontents := file readStreamDo: [ :stream | stream contents ].\relements := contents substrings: \'|\'.\r\rfila := 1.\rcolumna := 1.\rrandom := Random new.\rcantNPClocal := cantNPCs.\rmatrizTablero := Matrix rows: (cantJugadores sqrt) columns: (cantJugadores sqrt).\r\r1 to: cantJugadores do: [\r    jugador := Jugador new.\r    (cantNPClocal > 0 and: (random next < 0.2)) ifTrue: [\r        cantNPClocal := cantNPClocal - 1.\r        nombreJugador := UIManager default request: \'Por favor ingrese el nombre del participante\'.\r        (nombreJugador isEmptyOrNil) ifTrue: [\r            self error: \'Debe ingresar un nombre válido para continuar.\'\r        ].\r        jugador nombre: nombreJugador.\r        jugador nPC: false.\r    ] ifFalse: [\r        jugador nombre: (elements atRandom).\r        jugador nPC: true.\r    ].\r    jugador puntosProbabilidad: 0.\r    jugador tema: (self matrizDeTemas at: fila column: columna).\r\r    matrizTablero at: fila column: columna put: jugador.\r\r    fila := fila + 1.\r    (fila > cantJugadores sqrt) ifTrue: [\r        fila := 1.\r        columna := columna + 1.\r    ].\r].\r\rmatrizTablero inspect.\r',
