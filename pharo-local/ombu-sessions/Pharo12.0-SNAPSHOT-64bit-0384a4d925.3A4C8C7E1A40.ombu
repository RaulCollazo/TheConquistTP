	#tags : {
		#prior : OmReference [ '88' ],
		#self : OmReference [ '89' ]
	},
	#content : EpMethodAddition {
		#method : RGMethodDefinition {
			#annotations : IdentityDictionary {
				#className : #'Juego class',
				#isMeta : true
			},
			#name : #'jugadaValida:nombreJugador:labelMorph:',
			#protocol : #'as yet unclassified',
			#sourceCode : 'jugadaValida: cantNPC nombreJugador: nombreJugador labelMorph: labelMorph\r| filas columnas valido posJugador posMorph |\r    \r    filas := cantNPC sqrt ceiling.\r    columnas := filas.\r    valido := false.\r    \r    "Buscar posición del jugador"\r    posJugador := nil.\r    1 to: filas do: [ :fila |\r        1 to: columnas do: [ :columna |\r            ((TableroLogico matrizTableroLógico at: fila column: columna) nombre) = nombreJugador ifTrue: [\r                posJugador := {fila. columna}.\r            ].\r        ].\r    ].\r    \r    posJugador isNil ifTrue: [\r        Transcript show: \'El jugador no fue encontrado\'; cr.\r        ^ false.\r    ].\r    \r    "Buscar posición del Morph"\r    posMorph := nil.\r    1 to: filas do: [ :fila |\r        1 to: columnas do: [ :columna |\r            ((TableroLogico matrizDeMorphs at: fila column: columna) tema) = labelMorph ifTrue: [\r                posMorph := {fila. columna}.\r            ].\r        ].\r    ].\r    \r    posMorph isNil ifTrue: [\r        Transcript show: \'El Morph no fue encontrado\'; cr.\r        ^ false.\r    ].\r    \r    "Validar si el movimiento es válido (diagonal arriba/abajo)"\r    ((posMorph first = posJugador first + 1 and: [ posMorph second = posJugador second + 1 ]) or: \r    [ (posMorph first = posJugador first - 1 and: [ posMorph second = posJugador second + 1 ]) or: \r    [ (posMorph first = posJugador first - 1 and: [ posMorph second = posJugador second - 1 ]) ] ]) \r        ifTrue: [\r            valido := true.\r            Transcript show: \'La jugada es válida\'; cr.\r        ].\r    \r    Transcript show: \'La jugada es: \', valido asString; cr.\r    ^ valido.\r',
			#stamp : '2/8/2025 20:03',
			#package : #TheConquist
		}
	}
}OmEntry {
