			},
			#name : #'jugadaVálida:nombreJugador:labelMorph:',
			#protocol : #ManageJuego,
			#sourceCode : 'jugadaVálida: cantNPC nombreJugador: nombreJugador labelMorph: labelMorph\r| filajugador columnajugador filamorph columnamorph valido |\rfilajugador := 1.\rcolumnajugador := 1.\rfilamorph := 1.\rcolumnamorph := 1.\rvalido := false.\r\r1 to: (cantNPC sqrt ceiling) do: [ :i |\r    (filajugador > cantNPC sqrt ceiling) ifTrue: [\r        filajugador := 1.\r        columnajugador := columnajugador + 1\r    ].\r    (((TableroLogico matrizTableroLógico at: filajugador column: columnajugador) nombre) = nombreJugador) ifTrue: [\r        1 to: (cantNPC sqrt ceiling) do: [ :j |\r            (filamorph > cantNPC sqrt ceiling) ifTrue: [\r                filamorph := 1.\r                columnamorph := columnamorph + 1\r            ].\r            (((TableroLogico matrizDeMorphs at: filamorph column: columnamorph) tema) = labelMorph) ifTrue: [\r                (((filamorph = filajugador + 1) and: [columnamorph = columnajugador + 1]) or: [\r                    ((filamorph = filajugador - 1) and: [columnamorph = columnajugador + 1]) or: [\r                        ((filamorph = filajugador - 1) and: [columnamorph = columnajugador - 1])\r                    ]\r                ]) ifTrue: [\r                    valido := true.\r                    Transcript show: \'La jugada es válida\'; cr.\r                    ^self\r                ] ifFalse: [\r                    valido := false\r                ].\r            ].\r            filamorph := filamorph + 1.\r        ].\r    ].\r    filajugador := filajugador + 1.\r].\r\rTranscript show: \'La jugada no es válida\'; cr.\r^valido',
			#stamp : '2/8/2025 19:16',
			#package : #TheConquist
		}
	}
}OmEntry {
