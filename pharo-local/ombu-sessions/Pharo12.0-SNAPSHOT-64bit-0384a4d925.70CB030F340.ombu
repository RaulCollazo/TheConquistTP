			#name : #'ganaDesafiante:desafiado:',
			#protocol : #'as yet unclassified',
			#sourceCode : 'ganaDesafiante: desafiante desafiado: desafiado\r| fila columna remplazo |\rfila := 1.\rcolumna := 1.\rremplazo := nil.\r\r1 to: (self cantNPC sqrt ceiling) do: [:i |\r    (fila > self cantNPC sqrt ceiling) ifTrue: [ fila := 1. columna := columna + 1 ].\r    ((TableroLogico matrizDeMorphs at: fila column: columna) tema = desafiante tema) ifTrue: [ remplazo := (TableroLogico matrizDeMorphs at: fila column: columna) ].\r    fila := fila + 1.\r].\r\rfila := 1.\rcolumna := 1.\r\r1 to: (self cantNPC sqrt ceiling) do: [:i |\r    (fila > self cantNPC sqrt ceiling) ifTrue: [ fila := 1. columna := columna + 1 ].\r    ((TableroLogico matrizDeTemas at: fila column: columna) = desafiado tema) ifTrue: [\r        TableroLogico matrizDeTemas at: fila column: columna put: desafiante tema.\r        ((TableroLogico matrizDeMorphs at: fila column: columna) tema = desafiado tema) ifTrue: [\r            TableroLogico matrizDeTemas at: fila column: columna put: remplazo tema.\r        ].\r    ].\r    fila := fila + 1.\r].\rTranscript show: (\'Ganó el: \', desafiante nombre).',
			#stamp : '2/9/2025 03:17',
			#package : #TheConquist
		},
