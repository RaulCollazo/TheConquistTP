			},
			#name : #eliminarCasilla,
			#protocol : #'as yet unclassified',
			#sourceCode : 'eliminarCasilla\r    "Eliminar el Morph del mundo si existe"\r    morph ifNotNil: [\r        morph delete.\r        morph := nil.\r    ].',
			#stamp : '1/21/2025 16:54',
			#package : #TheConquist
		}
	}
}OmEntry {
