			#sourceCode : 'dibujarFondo\r    | imagen imagenMorph boton1 |\r    \r    "Cargar la imagen de fondo"\r    imagen := Form fromFileNamed: FileSystem workingDirectory / \'assets/backgrounds/background.png\'.\r    \r    "Crear ImageMorph para la imagen de fondo"\r    imagenMorph := ImageMorph new.\r    imagenMorph image: imagen.\r    imagenMorph position: 0@0. "Asegurarse de que la imagen de fondo esté en la esquina superior izquierda"\r    \r    "Crear el botón"\r    boton1 := SimpleButtonMorph new.\r    boton1 label: \'Nuevo Juego\'. "Definir el texto del botón"\r    boton1 action: [ Transcript show: \'Nuevo Juego\'; cr ]. "Definir la acción al presionar el botón"\r    \r    "Posicionar el botón en el centro de la imagen"\r    boton1 position: (imagenMorph width // 2 - (boton1 width // 2)) @ (imagenMorph height // 2 - (boton1 height // 2)).\r    \r    "Agregar el botón al ImageMorph"\r    imagenMorph addMorph: boton1.\r    \r    "Abrir el ImageMorph en el mundo"\r    imagenMorph openInWorld.',
