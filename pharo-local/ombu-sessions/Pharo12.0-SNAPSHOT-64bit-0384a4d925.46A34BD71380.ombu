	#content : EpMethodModification {
		#oldMethod : RGMethodDefinition {
			#annotations : IdentityDictionary {
				#className : #Juego,
				#isMeta : false
			},
			#name : #dibujarFondo,
			#protocol : #'as yet unclassified',
			#sourceCode : 'dibujarFondo\r|imagen boton1|\rimagen := Form fromFileNamed: FileSystem workingDirectory , \'/assets/backgrounds/background.png\'.\rimagenMorph := ImageMorph new.\rimagenMorph image: imagen.\r\rboton1 := PluggableButtonMorph new.\r    boton1 label: \'Nuevo Juego\'. "Define el texto del botón"\r    boton1 target: self. "Define el objetivo de la acción como la instancia actual"\r    boton1 actionSelector: [Transcript show: \'hola\';cr]. "Define el método a llamar cuando se presiona el botón"\r    boton1 position: (imagenMorph width // 2 - 50) @ (imagenMorph height // 2 - 20). "Posicionar el botón en el centro de la imagen"\rimagenMorph addMorph: boton1.\r\rimagenMorph openInWorld center.',
			#stamp : '1/21/2025 22:21',
			#package : #TheConquist
		},
		#newMethod : RGMethodDefinition {
			#annotations : IdentityDictionary {
				#className : #Juego,
				#isMeta : false
			},
			#name : #dibujarFondo,
			#protocol : #'as yet unclassified',
			#sourceCode : 'dibujarFondo\r    | imagen imagenMorph boton1 |\r    \r    "Cargar la imagen de fondo"\r    imagen := Form fromFileNamed: FileSystem workingDirectory / \'assets/backgrounds/background.png\'.\r    \r    "Crear ImageMorph para la imagen de fondo"\r    imagenMorph := ImageMorph new.\r    imagenMorph image: imagen.\r    imagenMorph position: 0@0. "Asegurarse de que la imagen de fondo esté en la esquina superior izquierda"\r    \r    "Crear el botón"\r    boton1 := PluggableButtonMorph new.\r    boton1 label: \'Nuevo Juego\'. "Definir el texto del botón"\r    boton1 target: self. "Definir el objetivo de la acción como la instancia actual"\r    boton1 actionSelector: #nuevoJuego. "Definir el método a llamar cuando se presiona el botón"\r    \r    "Posicionar el botón en el centro de la imagen"\r    boton1 position: (imagenMorph width // 2 - (boton1 width // 2)) @ (imagenMorph height // 2 - (boton1 height // 2)).\r    \r    "Agregar el botón al ImageMorph"\r    imagenMorph addMorph: boton1.\r    \r    "Abrir el ImageMorph en el mundo"\r    imagenMorph openInWorld.',
			#stamp : '1/21/2025 22:23',
			#package : #TheConquist
		}
	}
}OmEntry {
