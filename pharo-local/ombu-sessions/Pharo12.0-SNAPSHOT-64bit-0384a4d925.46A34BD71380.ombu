				#isMeta : false
			},
			#name : #dibujarFondo,
			#protocol : #'as yet unclassified',
			#sourceCode : 'dibujarFondo\r|imagen imagenMorph|\rimagen := Form fromFileNamed: FileSystem workingDirectory , \'/assets/backgrounds/background.png\'.\rimagenMorph := ImageMorph new.\rimagenMorph image: imagen.\rimagenMorph openInWorld.',
			#stamp : '1/21/2025 21:24',
