			#name : #'borrarVentanaLabeled:',
			#protocol : #'as yet unclassified',
			#sourceCode : 'borrarVentanaLabeled: unLabel\r    "Buscar y borrar una ventana con un label específico"\r    | ventana |\r    ventana := World submorphs detect: [ :morph | \r        (morph isKindOf: SystemWindow) and: [morph label = unLabel] ] ifNone: [nil].\r    ventana ifNotNil: [ventana delete].\r',
