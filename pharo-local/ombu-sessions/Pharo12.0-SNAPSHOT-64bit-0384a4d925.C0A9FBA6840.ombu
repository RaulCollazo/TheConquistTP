			#name : #removeAllMorphsFromImageMorphExceptBackground,
			#protocol : #'as yet unclassified',
			#sourceCode : 'removeAllMorphsFromImageMorphExceptBackground\r    "Elimina todos los morphs añadidos a imagenMorph excepto el background"\r    imagenMorph submorphs do: [:each | \r        (each isKindOf: ImageMorph) ifFalse: [ imagenMorph removeMorph: each ]\r    ].',
