			},
			#name : #obtenerJugadorTurnoActual,
			#protocol : #'as yet unclassified',
			#sourceCode : 'obtenerJugadorTurnoActual\r| listaPrioridad prioridadMáxima fila columna jugadorDeMatriz |\rprioridadMáxima := 0.\rlistaPrioridad := OrderedCollection new.\rfila := 1.\rcolumna := 1.\r\r1 to: Juego class cantNPC do: [ :i |\r    jugadorDeMatriz := (self matrizTableroLógico at: fila column: columna).\r\r    (jugadorDeMatriz puntosProbabilidad = prioridadMáxima) ifTrue: [ \r        listaPrioridad add: jugadorDeMatriz \r    ].\r\r    (jugadorDeMatriz puntosProbabilidad > prioridadMáxima) ifTrue: [ \r        listaPrioridad := OrderedCollection with: jugadorDeMatriz.\r        prioridadMáxima := jugadorDeMatriz puntosProbabilidad \r    ].\r\r    fila := fila + 1.\r    (fila > (Juego class cantNPC sqrt ceiling)) ifTrue: [ \r        fila := 1.\r        columna := columna + 1 \r    ].\r].\r\rjugadorDeMatriz := (listaPrioridad atRandom).\r^jugadorDeMatriz.',
			#stamp : '2/7/2025 15:23',
