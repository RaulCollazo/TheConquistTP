			#name : #'crearMatrizMorphs:',
			#protocol : #'as yet unclassified',
			#sourceCode : 'crearMatrizMorphs: cantMorphs\r|matrizMorphs fila columna|\rfila := 0.\rcolumna := 1.\rmatrizMorphs := Matrix rows: cantMorphs sqrt ceiling columns: cantMorphs sqrt ceiling. \r1 to: (cantMorphs sqrt) do: [:i|\r\t(fila := fila + i).\r\t matrizMorphs at: fila column: columna put: (self matrizDeTemas at: fila column: columna ).\r\t(fila = (cantMorphs sqrt)) ifTrue: [ fila := 0. columna:=columna +1].\t\r\t ].',
