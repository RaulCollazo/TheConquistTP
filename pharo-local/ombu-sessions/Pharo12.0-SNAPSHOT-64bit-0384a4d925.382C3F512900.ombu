				#isMeta : false
			},
			#name : #'crearCasilla:and:',
			#protocol : #'as yet unclassified',
			#sourceCode : 'crearCasilla: x and: y\r    "Crear un Morph cuadrado y almacenarlo en la variable de instancia"\r    morph := Morph new.\r    morph color: Color random.\r    morph extent: 100@100. "Tamaño del cuadrado (100x100 píxeles)"\r    morph position: x@y. "Posicionar el morph según las coordenadas pasadas"\r    World addMorph: morph.',
			#stamp : '1/24/2025 14:40',
			#package : #TheConquist
		},
		#newMethod : RGMethodDefinition {
			#annotations : IdentityDictionary {
				#className : #Casilla,
				#isMeta : false
			},
			#name : #'crearCasilla:and:',
			#protocol : #'as yet unclassified',
			#sourceCode : 'crearCasilla: x and: y\r|buttonMorph labelMorph|\rbuttonMorph := Morph new.\rbuttonMorph bounds: (50@50 extent: 100@50).\rbuttonMorph color: Color lightGray.\rbuttonMorph borderWidth: 2.\rbuttonMorph borderColor: Color black.\rbuttonMorph on: #mouseUp send: #value to: [ Transcript show: \'Botón clickeado\'; cr ].\rlabelMorph := StringMorph new.\rlabelMorph contents: \'Click Me\'.\rlabelMorph position: (buttonMorph bounds center - (labelMorph extent / 2)).\r\r"Agregar la etiqueta al botón"\rbuttonMorph addMorph: labelMorph.',
			#stamp : '1/27/2025 17:30',
			#package : #TheConquist
		}
	}
}OmEntry {
