		#self : OmReference [ '400' ]
	},
	#content : EpMethodAddition {
		#method : RGMethodDefinition {
			#annotations : IdentityDictionary {
				#className : #NeoJSONObjectTests,
				#isMeta : false
			},
			#name : #testAtAt,
			#protocol : #testing,
			#sourceCode : 'testAtAt\r\t| object |\r\tobject := NeoJSONObject new.\r\tself assert: (object at: #foo) isNil.\r\tself assert: (object at: #foo at: #bar) isNil.\r\tobject at: #foo at: #bar put: 123.\r\tself assert: (object at: #foo) notNil.\r\tself assert: (object at: #foo at: #bar) equals: 123.\r\tself assert: object foo bar equals: 123.\r\tobject at: #foo at: #bar put: -1.\r\tself assert: (object at: #foo at: #bar) equals: -1.\r\tself assert: (object at: #foo at: #foo) isNil',
			#stamp : '',
			#package : #Neo-JSON-Tests
		}
	}
