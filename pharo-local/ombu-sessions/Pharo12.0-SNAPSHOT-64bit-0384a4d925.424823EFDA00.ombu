			},
			#name : #testArray,
			#protocol : #testing,
			#sourceCode : 'testArray\r\t| jsonArray array |\r\tjsonArray := \'[1,2,3]\'.\r\tarray := NeoJSONObject fromString: jsonArray.\r\tself assert: array asString equals: jsonArray.\r\tself assertCollection: array hasSameElements: #(1 2 3).\r\tarray at: 1 add: 0.\r\tarray at: #- add: 4.\r\tself assertCollection: array hasSameElements: #(0 1 2 3 4).\r\tarray removeKey: 5.\r\tarray removeKey: 1.\r\tself assertCollection: array hasSameElements: #(1 2 3)',
			#stamp : '',
