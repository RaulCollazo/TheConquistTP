				#protocols : Set [ ],
				#instanceVariables : OrderedCollection [ ],
				#baseClass : @7
			},
			#comment : RGCommentDefinition {
				#annotations : IdentityDictionary {
					#className : #NeoJSONFloatPrinter,
					#isMeta : false
				},
				#parent : @7,
				#content : 'I am NeoJSONFloatPrinter.\r\rI print Float numbers in a compact, human friendly format.\r\rThe following (default) parameters are used:\r - base 10 - hardcoded (for now)\r - precision 5 digits\r - decimal point - hardcoded (for now)\r - exponent e - hardcoded (for now)\r - NaN, Inf and -Inf - hardcoded (for now)\r - lower 1e-4\r - upper 1e6\r - decimal notation for abs values inside abs [ lower, upper ]\r - scientific notation for abs values outside [ lower, upper ]\r - no padding, no trailing zeros in fraction part\r - only negative sign, never a positive sign\r - no thousands separators\r - no engineering notation\r\rSee my class side for configuration examples.\r\rMy public interface is in the printing protocol.\r',
				#stamp : ''
			},
			#classVariables : OrderedCollection [ ],
			#package : RGPackageDefinition {
				#name : #Neo-JSON-Core,
				#definedClasses : IdentityDictionary { },
				#definedMethods : IdentityDictionary { },
				#extensionMethods : IdentityDictionary { }
			},
			#packageTag : #Uncategorized,
			#sharedPools : OrderedCollection [ ]
		},
		#protocol : #printing
	}
}OmEntry {
