				#className : #NeoJSONArray,
				#isMeta : false
			},
			#name : #'findPath:',
			#protocol : #accessing,
			#sourceCode : 'findPath: conditionBlock\r\t"Find and return the first path to an object in the graph that I represent \r\tfor which conditionBlock holds. Return nil when not found."\r\r\t(conditionBlock value: self) ifTrue: [ ^ #(()) ].\r\tself doWithIndex: [ :value :index |\r\t\t(conditionBlock value: value) ifTrue: [ ^ { index } ].\r\t\t(value isCollection and: [ value isString not ]) ifTrue: [\r\t\t\t(value findPath: conditionBlock) ifNotNil: [ :subPath |\r\t\t\t\t^ { index } , subPath ] ] ].\r\t^ nil',
			#stamp : '',
			#package : #Neo-JSON-Core
		}
	}
}OmEntry {
