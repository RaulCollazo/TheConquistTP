			#sourceCode : 'print: float specialOn: stream\r\tfloat isZero\r\t\tifTrue: [ \r\t\t\tstream nextPut: $0 ]\r\t\tifFalse: [\r\t\t\tfloat isNaN \r\t\t\t\tifTrue: [ \r\t\t\t\t\tstream nextPutAll: self nan ]\r\t\t\t\tifFalse: [\r\t\t\t\t\tself print: float signOn: stream.\r\t\t\t\t\tstream nextPutAll: self infinite ] ]',
