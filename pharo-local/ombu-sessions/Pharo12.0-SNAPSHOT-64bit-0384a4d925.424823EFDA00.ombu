		#method : RGMethodDefinition {
			#annotations : IdentityDictionary {
				#className : #OrderedDictionary,
				#isMeta : false
			},
			#name : #'neoJsonOn:',
			#protocol : #'*neo-json-pharo-core',
			#sourceCode : 'neoJsonOn: neoJSONWriter\r\tneoJSONWriter writeMap: self',
			#stamp : '',
			#package : #Neo-JSON-Pharo-Core
		}
	}
}OmEntry {
	#tags : {
		#trigger : OmReference [ '594' ],
		#prior : OmReference [ '597' ],
		#self : OmReference [ '598' ]
	},
	#content : EpProtocolAddition {
		#behavior : RGClassDefinition {
			#annotations : IdentityDictionary {
				#traitCompositionSource : '{}',
				#definitionSource : 'Collection << #SmallDictionary\r\tslots: { #keys . #values . #size };\r\ttag: \'Dictionaries\';\r\tpackage: \'Collections-Unordered\'',
				#superclassName : #Collection
			},
			#name : #SmallDictionary,
			#methods : IdentityDictionary { },
			#protocols : Set [ ],
			#instanceVariables : OrderedCollection [
				RGInstanceVariableDefinition {
					#annotations : IdentityDictionary {
						#className : #SmallDictionary,
						#isMeta : false
					},
					#name : #keys,
					#parent : @7
				},
				RGInstanceVariableDefinition {
					#annotations : IdentityDictionary {
						#className : #SmallDictionary,
						#isMeta : false
					},
					#name : #values,
					#parent : @7
				},
				RGInstanceVariableDefinition {
					#annotations : IdentityDictionary {
						#className : #SmallDictionary,
						#isMeta : false
					},
					#name : #size,
					#parent : @7
				}
			],
			#metaClass : RGMetaclassDefinition {
				#annotations : IdentityDictionary {
					#definitionSource : 'Collection class << SmallDictionary class\r\tslots: {}',
					#traitCompositionSource : '{}'
				},
				#name : #'SmallDictionary class',
				#methods : IdentityDictionary { },
				#protocols : Set [ ],
				#instanceVariables : OrderedCollection [ ],
				#baseClass : @7
			},
			#comment : RGCommentDefinition {
				#annotations : IdentityDictionary {
					#className : #SmallDictionary,
					#isMeta : false
				},
				#parent : @7,
				#content : '`SmallDictionary` is a special dictionary optimized for small collections. In addition to the normal dictionary protocol, it also supports an `#empty` message which "empties" the collection but may hang on to the original elements (so it could collect garbage). Without `#empty` we would either need to create a new dictionary or explicitly remove everything from the dictionary. Both of these take more time and `#empty`. Be careful, I cannot have *nil* as key. \r\r### Public API and Key Messages\r\r- #at: aKey put: aValue / #at: aKey ifAbsentPut: aValue \t\tallow to add an element.  \r- #at: aKey / #at: aKey ifAbsent: aBlock / #at: aKey ifPresent: aBlock ifAbsent: aBlock \t\tallow to access my values.\r- #keysDo: aBlock / #valuesDo: aBlock / #associationsDo: \t\tallow to iterate on me effectively\r\r### Examples \r\r\rTo create a dictiony with indexes as key: \r\r```\rSmallDictionary withAll: #(7 3 1 3)   \t\t\r">>>  a SmallDictionaryDictionary(1->7 2->3 3->1 4->3 "\r```\rTo use Objects as key (here symbols): \r\r```\r\tcolors := SmallDictionary new \r\t\t\t\tat: #yellow put: Color yellow; \r\t\t\t\tat: #blue put: Color blue;\r\t\t\t\tat: #red put: Color red;\r\t\t\t\tyourself.\r\t\t\t\t\r\tcolors at: #yellow. \t"returns:  Color yellow"\r\tcolors keys          \t\t"returns: a Set(#blue #yellow #red)"\r\tcolors values     \t\t"returns:  {Color blue. Color yellow. Color red}"\r\r\tcolors empty \t"a SmallDictionary()"\r```\r\r### Internal Representation and Key Implementation Points.\rInstance Variables\r- keys:\t\t<Array>\t\tArray of keys (we don\'t use Associations for our key value pairs)\r- size:\t\t\t<Integer>\tSize of the dictionary\r- values:\t\t<Array>\t\tArray of our values\r\r\r    Implementation Points',
				#stamp : ''
			},
			#classVariables : OrderedCollection [ ],
			#package : RGPackageDefinition {
				#name : #Collections-Unordered,
				#definedClasses : IdentityDictionary { },
				#definedMethods : IdentityDictionary { },
				#extensionMethods : IdentityDictionary { }
			},
			#packageTag : #Dictionaries,
			#sharedPools : OrderedCollection [ ]
		},
		#protocol : #'*neo-json-pharo-core'
	}
}OmEntry {
