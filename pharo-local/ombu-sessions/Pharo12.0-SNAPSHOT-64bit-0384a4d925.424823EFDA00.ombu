			#name : #exampleSimpleUsage,
			#protocol : #example,
			#sourceCode : 'exampleSimpleUsage\r\t<gtExample>\r\t| simple |\r\tsimple := NeoJSONObject exampleSimple.\r\tself assert: simple foo equals: (simple at: #foo).\r\tself assert: (simple foo: -1) equals: (simple at: #foo put: -1; yourself).\r\tself assert: (simple includesKey: #baz) not.\r\tself assert: simple baz equals: nil.\r\t^ simple',
