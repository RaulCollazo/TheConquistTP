			#sourceCode : 'doesCodePointNeedEscaping: code\r\tcode < 32 ifTrue: [ ^ true ].\r\t( code = 34 or: [ code = 92 ]) ifTrue: [ ^ true ].\r\t^ asciiOnly and: [ code > 126 ]\t',
