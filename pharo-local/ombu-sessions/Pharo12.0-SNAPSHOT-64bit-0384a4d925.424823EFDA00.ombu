			#annotations : IdentityDictionary {
				#className : #NeoJSONFloatPrinter,
				#isMeta : false
			},
			#name : #'print:scientificOn:',
			#protocol : #private,
			#sourceCode : 'print: float scientificOn: stream\r\t| exponent mantissa |\r\texponent := (float ln / base ln) floor.\r\tmantissa := float / (base raisedTo: exponent).\r\tself print: mantissa decimalOn: stream.\r\tstream\r\t\tnextPut: self exponent;\r\t\tprint: exponent',
			#stamp : '',
			#package : #Neo-JSON-Core
		}
	}
