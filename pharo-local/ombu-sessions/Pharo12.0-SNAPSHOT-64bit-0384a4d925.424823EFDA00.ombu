			#sourceCode : 'testWellKnownConstants\r\tself assert: (printer print: Float pi) equals: \'3.14159\'.\r\tself assert: (printer print: Float e) equals: \'2.71828\'.\r\t"the earth\'s mass in kg"\r\tself assert: (printer print: 5.9724e24) equals: \'5.9724e24\'.\r\t"mass of electron in kg"\r\tself assert: (printer print: 9.10938356e-31) equals: \'9.10938e-31\'.\r\t"planck\'s constant in Js"\r\tself assert: (printer print: 1.05457e-34) equals: \'1.05457e-34\'.\r\t"speed of light in m/s"\r\tself assert: (printer print: 2.99792e8) equals: \'2.99792e8\'.\r\t"charge of electron in C"\r\tself assert: (printer print: -1.60218e-19) equals: \'-1.60218e-19\'.\r\t"boltzmann\'s constant in J/K"\r\tself assert: (printer print: 1.38065e-23) equals: \'1.38065e-23\'.\r',
