			#sourceCode : 'runNativeJsonBenchmarkJsonCheckerFailures\r\t^ self\r\t\tvalidateFiles: self nativeJsonBenchmarkJsonCheckerFailFiles\r\t\tusingTest: [ :file | \r\t\t\t| data success |\r\t\t\tsuccess := false.\r\t\t\t[ data := file readStreamDo: [ :in | (NeoJSONReader on: in) next; failIfNotAtEnd ] ]\r\t\t\t\ton: NeoJSONParseError\r\t\t\t\tdo: [ :exception | self log: exception printString. success := true ].\r\t\t\tsuccess ]',
			#stamp : '',
			#package : #Neo-JSON-Tests
		}
	}
}OmEntry {
