	},
	#content : EpProtocolAddition {
		#behavior : RGMetaclassDefinition {
			#annotations : IdentityDictionary {
				#definitionSource : 'Error class << NeoJSONMappingNotFound class\r\tslots: {}',
				#traitCompositionSource : '{}'
			},
			#name : #'NeoJSONMappingNotFound class',
			#methods : IdentityDictionary { },
			#protocols : Set [ ],
			#instanceVariables : OrderedCollection [ ],
			#baseClass : RGClassDefinition {
				#annotations : IdentityDictionary {
					#traitCompositionSource : '{}',
					#definitionSource : 'Error << #NeoJSONMappingNotFound\r\tslots: { #object . #collection };\r\tpackage: \'Neo-JSON-Core\'',
					#superclassName : #Error
				},
				#name : #NeoJSONMappingNotFound,
				#methods : IdentityDictionary { },
				#protocols : Set [ ],
				#instanceVariables : OrderedCollection [
					RGInstanceVariableDefinition {
						#annotations : IdentityDictionary {
