	#content : EpMethodAddition {
		#method : RGMethodDefinition {
			#annotations : IdentityDictionary {
				#className : #NeoJSONFloatPrinter,
				#isMeta : false
			},
			#name : #'print:on:',
			#protocol : #printing,
			#sourceCode : 'print: float on: stream\r\t| int abs |\r\t(float isZero or: [ float isFinite not ])\r\t\tifTrue: [ ^ self print: float specialOn: stream ].\r\tself print: float signOn: stream.\r\t((abs := float abs) between: lower and: upper)\r\t\tifTrue: [ \r\t\t\t(int := abs asInteger) = abs \r\t\t\t\tifTrue: [ int printOn: stream ]\r\t\t\t\tifFalse: [ self print: abs decimalOn: stream ] ]\r\t\tifFalse: [ self print: abs scientificOn: stream ]',
			#stamp : '',
			#package : #Neo-JSON-Core
		}
	}
}OmEntry {
	#tags : {
		#trigger : OmReference [ '8' ],
