	#tags : {
		#trigger : OmReference [ '335' ],
		#prior : OmReference [ '377' ],
		#self : OmReference [ '378' ]
	},
	#content : EpMethodAddition {
		#method : RGMethodDefinition {
			#annotations : IdentityDictionary {
				#className : #NeoJSONExamplesTests,
				#isMeta : false
			},
			#name : #testMultiInstances,
			#protocol : #tests,
			#sourceCode : 'testMultiInstances\r\t"Newline delimited JSON (application/x-ndjson) - https://github.com/ndjson/ndjson-spec"\r\t"JSON Lines (application/jsonl) - https://jsonlines.org"\r\r\t| data json |\r\t\r\tdata := (1 to: 10) collect: [ :each |\r\t\t{ #number -> each } asDictionary ].\r\t\r\tjson := String streamContents: [ :out |\r\t\t(NeoJSONWriter on: out) nextPutAll: data ].\r\t\r\tself assert: (NeoJSONReader on: json readStream) upToEnd equals: data.\r\t\r\tself assert: (NeoJSONReader on: json readStream) next equals: data first.\r\tself deny: ((NeoJSONReader on: json readStream) next; atEnd)',
			#stamp : '',
			#package : #Neo-JSON-Tests
		}
	}
}OmEntry {
	#tags : {
		#trigger : OmReference [ '335' ],
		#prior : OmReference [ '378' ],
		#self : OmReference [ '379' ]
	},
	#content : EpMethodAddition {
		#method : RGMethodDefinition {
			#annotations : IdentityDictionary {
				#className : #NeoJSONExamplesTests,
				#isMeta : false
			},
			#name : #testPoints,
			#protocol : #tests,
			#sourceCode : 'testPoints\r\t| points json result |\r\t\r\tpoints := Array with: 1@2 with: 3@4 with: 5@6.\r\t\r\tjson := String streamContents: [ :out |\r\t\t(NeoJSONWriter on: out)\r\t\t\tprettyPrint: true;\r\t\t\tmapInstVarsFor: Point;\r\t\t\tnextPut: points ].\r\t\t\r\tresult := (NeoJSONReader on: json readStream)\r\t\tmapInstVarsFor: Point;\r\t\tfor: #ListOfPoints customDo: [ :mapping |\r\t\t\tmapping listOfElementSchema: Point ];\r\t\tnextAs: #ListOfPoints.\r\t\r\tself assert: result equals: points.\r\t\t\t\r\tresult := (NeoJSONReader on: json readStream)\r\t\tmapInstVarsFor: Point;\r\t\tnextListAs: Point.\r\t\r\tself assert: result equals: points.\r\t\t\r\tresult := (NeoJSONReader on: json readStream)\r\t\tmapInstVarsFor: Point;\r\t\tfor: #OrderedCollectionOfPoints customDo: [ :mapping |\r\t\t\tmapping listOfType: OrderedCollection andElementSchema: Point ];\r\t\tnextAs: #OrderedCollectionOfPoints.\r\t\r\tself assert: result equals: points asOrderedCollection.',
			#stamp : '',
			#package : #Neo-JSON-Tests
		}
	}
}OmEntry {
	#tags : {
		#trigger : OmReference [ '335' ],
		#prior : OmReference [ '379' ],
		#self : OmReference [ '380' ]
	},
	#content : EpMethodAddition {
		#method : RGMethodDefinition {
			#annotations : IdentityDictionary {
				#className : #NeoJSONExamplesTests,
				#isMeta : false
			},
			#name : #testRectanglePoints,
			#protocol : #tests,
			#sourceCode : 'testRectanglePoints\r\t| rectangle rectangleJson result |\r\r\trectangle := Rectangle origin: 3 @ 4 extent: 5 @ 6.\r\r\trectangleJson := String streamContents: [ :stream | \r\t\t(NeoJSONWriter on: stream)\r\t\t\tprettyPrint: true;\r\t\t\tmapInstVarsFor: Point;\r\t\t\tmapInstVarsFor: Rectangle;\r\t\t\tnextPut: rectangle ].\r\r\tresult := (NeoJSONReader on: rectangleJson readStream)\r\t\tmapInstVarsFor: Point;\r\t\tfor: Rectangle do: [ :mapping | \r\t\t\t(mapping mapInstVar: #origin) valueSchema: Point.\r\t\t\t(mapping mapInstVar: #corner) valueSchema: Point ];\r\t\tnextAs: Rectangle.\r\r\tself assert: result equals: rectangle.\r\r\tresult := (NeoJSONReader on: rectangleJson readStream)\r\t\tmapInstVarsFor: Point;\r\t\tfor: Rectangle do: [ :mapping | \r\t\t\tmapping mapInstVars do: [ :each | each valueSchema: Point ] ];\r\t\tnextAs: Rectangle.\r\t\t\r\tself assert: result equals: rectangle ',
			#stamp : '',
			#package : #Neo-JSON-Tests
		}
	}
}OmEntry {
