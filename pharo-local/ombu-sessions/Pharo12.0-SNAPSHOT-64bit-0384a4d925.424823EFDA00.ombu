		#method : RGMethodDefinition {
			#annotations : IdentityDictionary {
				#className : #NeoJSONFloatPrinter,
				#isMeta : false
			},
			#name : #'print:decimalOn:',
			#protocol : #private,
			#sourceCode : 'print: float decimalOn: stream\r\tstream print: float asInteger.\r\tstream nextPut: self decimalPoint.\r\tself \r\t\tprint: (float fractionPart * (base raisedTo: precision)) rounded \r\t\tfractionOn: stream',
			#stamp : '',
			#package : #Neo-JSON-Core
		}
