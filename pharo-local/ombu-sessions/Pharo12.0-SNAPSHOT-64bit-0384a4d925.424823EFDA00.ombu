	#tags : {
		#trigger : OmReference [ '335' ],
		#prior : OmReference [ '384' ],
		#self : OmReference [ '385' ]
	},
	#content : EpMethodAddition {
		#method : RGMethodDefinition {
			#annotations : IdentityDictionary {
				#className : #NeoJSONFloatPrinterTests,
				#isMeta : false
			},
			#name : #testDecimalNotation,
			#protocol : #tests,
			#sourceCode : 'testDecimalNotation\r\tself assert: (printer print: 1.5) equals: \'1.5\'.\r\tself assert: (printer print: -1.5) equals: \'-1.5\'.\r\tself assert: (printer print: 0.5) equals: \'0.5\'.\r\tself assert: (printer print: -0.5) equals: \'-0.5\'.\r\tself assert: (printer print: (1/3) asFloat) equals: \'0.33333\'.\r\tself assert: (printer print: (-1/3) asFloat) equals: \'-0.33333\'.\r\tself assert: (printer print: 0.00123) equals: \'0.00123\'.\r\tself assert: (printer print: -0.00123) equals: \'-0.00123\'.\r\tself assert: (printer print: 0.00012) equals: \'0.00012\'.\r\tself assert: (printer print: -0.00012) equals: \'-0.00012\'.\r\tself assert: (printer print: 123456.12345) equals: \'123456.12345\'.\r\tself assert: (printer print: -123456.12345) equals: \'-123456.12345\'.\r',
			#stamp : '',
			#package : #Neo-JSON-Tests
		}
	}
}OmEntry {
