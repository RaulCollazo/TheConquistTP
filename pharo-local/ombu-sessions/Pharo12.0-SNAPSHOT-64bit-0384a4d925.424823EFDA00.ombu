			#sourceCode : 'runNativeJsonBenchmarkRoundTrip\r\t^ self \r\t\tvalidateFiles: self nativeJsonBenchmarkRoundTripFiles\r\t\tusingTest: [ :file |\r\t\t\t| data json |\r\t\t\tdata := file readStreamDo: [ :in | (NeoJSONReader on: in) next ].\r\t\t\tjson := NeoJSONWriter toString: data.\r\t\t\tjson = file contents ]',
			#stamp : '',
			#package : #Neo-JSON-Tests
		}
	}
}OmEntry {
	#tags : {
