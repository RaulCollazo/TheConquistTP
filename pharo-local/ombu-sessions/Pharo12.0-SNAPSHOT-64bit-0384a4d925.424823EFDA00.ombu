			},
			#name : #exampleMagnitudeClassHierarchy,
			#protocol : #example,
			#sourceCode : 'exampleMagnitudeClassHierarchy\r\t<gtExample>\r\t| builder |\r\tbuilder := [ :aClass | \r\t\tNeoJSONObject new\r\t\t\tname: aClass name;\r\t\t\tsuperclass: aClass superclass name;\r\t\t\tinstanceVariables: aClass instVarNames;\r\t\t\tcategory: aClass category;\r\t\t\ttotalInstanceVariablesCount: aClass allInstVarNames size;\r\t\t\tmethodCount: aClass methods size;\r\t\t\ttotalMethodCount: aClass allMethods size;\r\t\t\tsubclasses: (aClass subclasses \r\t\t\t\t\t\t\t\tcollect: [ :aSubclass | builder value: aSubclass ] \r\t\t\t\t\t\t\t\tas: NeoJSONArray) ].\r\t^ builder value: Magnitude',
			#stamp : '',
			#package : #Neo-JSON-Core
		}
	}
