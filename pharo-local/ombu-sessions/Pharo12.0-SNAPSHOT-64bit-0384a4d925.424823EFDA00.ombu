			#sourceCode : 'testPreservePropertyOrder\r\t| writer testObject |\r\t(testObject := NeoJSONTestObject2 new)\r\t\tid: 123;\r\t\twidth: 100;\r\t\theight: 50;\r\t\tdata: \'test\'.\r\twriter := [ :object | \r\t\tString streamContents: [ :stream |\r\t\t\t(NeoJSONWriter on: stream) \r\t\t\t\tfor: NeoJSONTestObject2 do: [ :mapping | mapping mapInstVars: #(id width height data) ];\r\t\t\t\tnextPut: object ] ].\r\tself assert: (writer value: testObject) equals: \'{"id":123,"width":100,"height":50,"data":"test"}\'.\r\twriter := [ :object | \r\t\tString streamContents: [ :stream |\r\t\t\t(NeoJSONWriter on: stream) \r\t\t\t\tfor: NeoJSONTestObject2 do: [ :mapping | mapping mapInstVars: #(width height data id) ];\r\t\t\t\tnextPut: object ] ].\r\tself assert: (writer value: testObject) equals: \'{"width":100,"height":50,"data":"test","id":123}\'.\r\twriter := [ :object | \r\t\tString streamContents: [ :stream |\r\t\t\t(NeoJSONWriter on: stream) \r\t\t\t\tfor: NeoJSONTestObject2 do: [ :mapping | mapping mapInstVars: #(data id height width) ];\r\t\t\t\tnextPut: object ] ].\r\tself assert: (writer value: testObject) equals: \'{"data":"test","id":123,"height":50,"width":100}\'.\r',
			#stamp : '',
			#package : #Neo-JSON-Tests
		}
	}
