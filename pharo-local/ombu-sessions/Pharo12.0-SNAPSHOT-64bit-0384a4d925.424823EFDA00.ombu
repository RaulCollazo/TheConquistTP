			#sourceCode : 'writeObject: anObject on: jsonMapWriter\r\t| value |\r\tvalue := getter value: anObject.\r\t(value notNil or: [ jsonMapWriter writeNil ])\r\t\tifTrue: [ jsonMapWriter writeKey: propertyName value: value as: valueSchema ] ',
