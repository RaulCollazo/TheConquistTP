			#name : #'findPaths:',
			#protocol : #accessing,
			#sourceCode : 'findPaths: conditionBlock\r\t"Find and return all paths to objects in the graph that I represent \r\tfor which conditionBlock holds. Return an empty collection when none are found."\r\r\t| found |\r\tfound := OrderedCollection new.\t\r\tself doWithIndex: [ :value :index |\r\t\t(conditionBlock value: value) ifTrue: [ found add: { index } ].\r\t\t(value isCollection and: [ value isString not ]) ifTrue: [\r\t\t\t(value findPaths: conditionBlock) do: [ :subPath |\r\t\t\t\tfound add: { index } , subPath ] ] ].\r\t^ found',
			#stamp : '',
			#package : #Neo-JSON-Core
		}
	}
}OmEntry {
