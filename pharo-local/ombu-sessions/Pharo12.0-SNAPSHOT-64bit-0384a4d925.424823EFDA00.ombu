	#tags : {
		#trigger : OmReference [ '8' ],
		#prior : OmReference [ '323' ],
		#self : OmReference [ '324' ]
	},
	#content : EpMethodAddition {
		#method : RGMethodDefinition {
			#annotations : IdentityDictionary {
				#className : #NeoJSONObject,
				#isMeta : false
			},
			#name : #'doesNotUnderstand:',
			#protocol : #'reflective operations',
			#sourceCode : 'doesNotUnderstand: message\r\t"Overwritten so that \'self foo\' becomes \'self at: #foo\'\r\tand \'self foo: 1\' becomes \'self at: #foo put: 1\' except that self is returned"\r\r\t| key |\r\tkey := message selector.\r\tkey isUnary\r\t\tifTrue: [ ^ self at: key ].\r\t^ (key isKeyword and: [ key numArgs = 1 ])\r\t\tifTrue: [ self at: key allButLast asSymbol put: message arguments first; yourself ]\r\t\tifFalse: [ super doesNotUnderstand: message ]',
			#stamp : '',
			#package : #Neo-JSON-Core
		}
	}
}OmEntry {
	#tags : {
		#trigger : OmReference [ '8' ],
		#prior : OmReference [ '324' ],
		#self : OmReference [ '325' ]
	},
	#content : EpMethodAddition {
		#method : RGMethodDefinition {
			#annotations : IdentityDictionary {
				#className : #NeoJSONObject,
				#isMeta : false
			},
			#name : #'findPath:',
			#protocol : #accessing,
			#sourceCode : 'findPath: conditionBlock\r\t"Find and return the first path to an object in the graph that I represent \r\tfor which conditionBlock holds. Return nil when not found."\r\r\t(conditionBlock value: self) ifTrue: [ ^ #(()) ].\r\tself keysAndValuesDo: [ :key :value |\r\t\t(conditionBlock value: value) ifTrue: [ ^ { key } ].\r\t\t(value isCollection and: [ value isString not ]) ifTrue: [\r\t\t\t(value findPath: conditionBlock) ifNotNil: [ :subPath |\r\t\t\t\t^ { key } , subPath ] ] ].\r\t^ nil',
			#stamp : '',
			#package : #Neo-JSON-Core
		}
	}
}OmEntry {
	#tags : {
		#trigger : OmReference [ '8' ],
		#prior : OmReference [ '325' ],
		#self : OmReference [ '326' ]
	},
	#content : EpMethodAddition {
		#method : RGMethodDefinition {
			#annotations : IdentityDictionary {
				#className : #NeoJSONObject,
				#isMeta : false
			},
			#name : #'findPaths:',
			#protocol : #accessing,
			#sourceCode : 'findPaths: conditionBlock\r\t"Find and return all paths to objects in the graph that I represent \r\tfor which conditionBlock holds. Return an empty collection when none are found."\r\r\t| found |\r\tfound := OrderedCollection new.\r\tself keysAndValuesDo: [ :key :value |\r\t\t(conditionBlock value: value) ifTrue: [ found add: { key } ].\r\t\t(value isCollection and: [ value isString not ]) ifTrue: [\r\t\t\t(value findPaths: conditionBlock) do: [ :subPath |\r\t\t\t\tfound add: { key } , subPath ] ] ].\r\t^ found',
			#stamp : '',
			#package : #Neo-JSON-Core
		}
	}
}OmEntry {
