	#tags : {
		#trigger : OmReference [ '8' ],
		#prior : OmReference [ '52' ],
		#self : OmReference [ '53' ]
	},
	#content : EpMethodAddition {
		#method : RGMethodDefinition {
			#annotations : IdentityDictionary {
				#className : #NeoJSONFloatPrinter,
				#isMeta : false
			},
			#name : #'print:fractionOn:',
			#protocol : #private,
			#sourceCode : 'print: fractionPart fractionOn: stream\r\t| zeros |\r\tzeros := 0. "leading zeros are significant, trailing zeros are not printed"\r\tprecision to: 1 by: -1 do: [ :position | | digit |\r\t\tdigit := fractionPart digitAt: position base: base.\r\t\tdigit = 0\r\t\t\tifTrue: [ zeros := zeros +1 ]\r\t\t\tifFalse: [\r\t\t\t\tzeros > 0 ifTrue: [ \r\t\t\t\t\tzeros timesRepeat: [ stream nextPut: $0 ]. \r\t\t\t\t\tzeros := 0 ].\r\t\t\t\tstream nextPut: digit asCharacterDigit ] ]',
			#stamp : '',
			#package : #Neo-JSON-Core
		}
	}
}OmEntry {
	#tags : {
		#trigger : OmReference [ '8' ],
