	#content : EpMethodAddition {
		#method : RGMethodDefinition {
			#annotations : IdentityDictionary {
				#className : #NeoJSONMapper,
				#isMeta : false
			},
			#name : #'customMappingFor:',
			#protocol : #private,
			#sourceCode : 'customMappingFor: schemaName\r\t^ self mappings\r\t\tat: schemaName\r\t\tifAbsentPut: [ \r\t\t\tNeoJSONCustomMapping new\r\t\t\t\tschemaName: schemaName;\r\t\t\t\tyourself ]',
			#stamp : '',
