			#protocol : #example,
			#sourceCode : 'exampleNumbers\r\t<gtExample>\r\t| numbers |\r\tnumbers := self new: 128 withAll: nil.\r\t0 to: 127 do: [ :n | \r\t\tnumbers\r\t\t\tat: n + 1\r\t\t\tput: (NeoJSONObject new\r\t\t\t\t\tinteger: n;\r\t\t\t\t\tdecimal: (n printStringBase: 10);\r\t\t\t\t\toctal: (n printStringBase: 8);\r\t\t\t\t\thexadecimal: (n printStringBase: 16);\r\t\t\t\t\tbinary: (n printStringBase: 2);\r\t\t\t\t\troman: n printStringRoman;\r\t\t\t\t\twords: n asWords;\r\t\t\t\t\tprime: n isPrime;\r\t\t\t\t\tcharacter: n asCharacter asString) ].\r\t^ numbers',
			#stamp : '',
			#package : #Neo-JSON-Core
		}
	}
}OmEntry {
