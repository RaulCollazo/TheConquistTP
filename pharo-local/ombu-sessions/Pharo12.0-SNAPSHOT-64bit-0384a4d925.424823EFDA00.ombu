			#protocol : #example,
			#sourceCode : 'exampleCoordinates\r\t<gtExample>\r\t^ (0 to: 4) \r\t\tcollect: [ :each | self new x: each; y: each * 2 ]\r\t\tas: NeoJSONArray',
			#stamp : '',
