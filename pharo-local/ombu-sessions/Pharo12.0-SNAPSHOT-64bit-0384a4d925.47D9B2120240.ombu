			#protocol : #ManageJuego,
			#sourceCode : 'dibujarFondoTablero\r   | imagen imagenMorph scrollPane ventanaExistente ventana screenSize |\r\r        "Cargar la imagen de fondo"\r        imagen := Form fromFileNamed: FileSystem workingDirectory / \'assets/backgrounds/background-table.jpg\'.\r\r        "Crear ImageMorph para la imagen de fondo"\r        imagenMorph := ImageMorph new.\r        imagenMorph image: imagen.\r        imagenMorph position: 0@0. "Asegurarse de que la imagen de fondo esté en la esquina superior izquierda"\r\r        "Crear un ScrollPane y agregar el ImageMorph"\r        scrollPane := ScrollPane new.\r        scrollPane scroller addMorph: imagenMorph.\r        scrollPane extent: (300@300). "Ajustar el tamaño del ScrollPane según sea necesario"\r\r        "Dibujar el tablero en el ImageMorph"\r        TableroLogico dibujarTablero: imagenMorph cantNPC: CantNPC.\r\r        "Cerrar cualquier ventana existente etiquetada \'TheConquist Board\'"\r        ventanaExistente := SystemWindow allInstances detect: [ :each | each label = \'TheConquist\' ] ifNone: [ nil ].\r        ventanaExistente ifNotNil: [ ventanaExistente close ].\r\r        "Obtener el tamaño de la pantalla"\r        screenSize := World extent.\r\r        "Abrir el ScrollPane en una ventana"\r        ventana := scrollPane openInWindowLabeled: \'TheConquist Board\'.\r\r        "Simular pantalla completa"\r        [ventana position: 0@0.\r        ventana extent: screenSize.\r        ventana borderWidth: 0] ensure: [ventana show].\r    ',
