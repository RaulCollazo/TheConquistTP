		#oldMethod : RGMethodDefinition {
			#annotations : IdentityDictionary {
				#className : #'TableroLogico class',
				#isMeta : true
			},
			#name : #'crearMatrizTablero:NPCs:',
			#protocol : #'CreaciónyManejodeMAtrices',
			#sourceCode : 'crearMatrizTablero: cantJugadores NPCs: cantNPCs\r| matrizTablero fila columna cantNPClocal random file contents elements jugador jugadoresHumanos indicesHumanos totalJugadores |\rfile := FileSystem workingDirectory / \'assets\' / \'nombresNPC.txt\'.\rcontents := file readStreamDo: [ :stream | stream contents ].\r"Divide el contenido del archivo en elementos usando \'|\' como delimitador"\relements := contents substrings: \'|\'.\relements := elements shuffled. "Mezclar los elementos"\r\rfila := 1.\rcolumna := 1.\rrandom := Random new.\rcantNPClocal := cantNPCs.\rjugadoresHumanos := cantJugadores - cantNPCs.\rtotalJugadores := cantJugadores.\r\r"La matriz tablero va a estar compuesta por el objeto jugadores, que contendrá en cada posición los datos del jugador, si es NPC o no, su tema y sus puntos"\rmatrizTablero := Matrix rows: (cantJugadores sqrt ceiling) columns: (cantJugadores sqrt ceiling).\r\r"Generar una distribución equitativa para jugadores humanos"\rindicesHumanos := OrderedCollection new.\r1 to: totalJugadores do: [:i |\r    (indicesHumanos size < jugadoresHumanos and: [(i - 1) \\\\ (totalJugadores // jugadoresHumanos) = 0]) ifTrue: [\r        indicesHumanos add: i.\r    ].\r].\r\r1 to: totalJugadores do: [:i |\r    jugador := Jugador new.\r    \r    (indicesHumanos includes: i) ifTrue: [\r        "Asignar jugador humano"\r        jugador nombre: (UIManager default request: \'Por favor ingrese el nombre del participante\').\r        jugador nPC: false.\r        jugadoresHumanos := jugadoresHumanos - 1.\r    ] ifFalse: [\r        "Asignar jugador NPC"\r        jugador nombre: (elements atRandom).\r        jugador nPC: true.\r        cantNPClocal := cantNPClocal - 1.\r    ].\r\r    jugador puntosProbabilidad: 0.\r    jugador tema: (TableroLogico matrizDeTemas at: fila column: columna).\r\r    matrizTablero at: fila column: columna put: jugador.\r\r    (fila = matrizTablero rows) ifTrue: [\r        fila := 1.\r        columna := columna + 1.\r    ] ifFalse: [\r        fila := fila + 1.\r    ].\r].\r\rself matrizTableroLógico: matrizTablero.\rself inspect.',
			#stamp : '2/14/2025 00:11',
			#package : #TheConquist
		},
		#newMethod : RGMethodDefinition {
			#annotations : IdentityDictionary {
