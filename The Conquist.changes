ileTrue: [        CantNPC := (UIManager default request: '¿Cuántos participantes hay?') asNumber.        ((CantNPC sqrt isInteger))             ifTrue: [ flag := true ]            ifFalse: [ UIManager default inform: 'Valor inválido' ].    ].    "Solicitar la cantidad de jugadores humanos"    CantJugadores := (UIManager default request: '¿Cuántos participantes humanos habrá?') asNumber.MatrizTemas := TableroLogico new.MatrizTemas crearMatrizTemas: CantNPC.MatrizTemas inspect.! !!TableroLogico methodsFor: 'as yet unclassified' stamp: '1/23/2025 18:03' prior: 120825!crearMatrizTemas: cantJugadores| file contents elements matrix |"Abre el archivo y lee su contenido"file := FileSystem workingDirectory / 'assets' / 'temas.txt'.contents := file readStreamDo: [ :stream | stream contents ]."Divide el contenido del archivo en elementos usando '|' como delimitador"elements := contents substrings: '|'.    "Crear la matriz"    matrix := Matrix rows: (cantJugadores sqrt) columns: (cantJugadores sqrt).    "Recorrer los elementos y asignarlos a la matriz"    1 to: elements size do: [:i |        | row col |        row := (i - 1) // 8 + 1.  "Calcula la fila (1 a 8)"        col := (i - 1) \\ 8 + 1.   "Calcula la columna (1 a 8)"        matrix at: row column: col put: (elements at: i).    ].elements inspect! !!TableroLogico methodsFor: 'as yet unclassified' stamp: '1/23/2025 18:05' prior: 234453!crearMatrizTemas: cantJugadores| file contents elements matrix |"Abre el archivo y lee su contenido"file := FileSystem workingDirectory / 'assets' / 'temas.txt'.contents := file readStreamDo: [ :stream | stream contents ]."Divide el contenido del archivo en elementos usando '|' como delimitador"elements := contents substrings: '|'.    "Crear la matriz"    matrix := Matrix rows: (cantJugadores sqrt) columns: (cantJugadores sqrt).    "Recorrer los elementos y asignarlos a la matriz"    1 to: elements size do: [:i |        | row col |        row := (i - 1) // 8 + 1.  "Calcula la fila (1 a 8)"        col := (i - 1) \\ 8 + 1.   "Calcula la columna (1 a 8)"        matrix at: row column: col put: (elements at: i - 1).    ].elements inspect! !!TableroLogico methodsFor: 'as yet unclassified' stamp: '1/23/2025 18:05' prior: 236155!crearMatrizTemas: cantJugadores| file contents elements matrix |"Abre el archivo y lee su contenido"file := FileSystem workingDirectory / 'assets' / 'temas.txt'.contents := file readStreamDo: [ :stream | stream contents ]."Divide el contenido del archivo en elementos usando '|' como delimitador"elements := contents substrings: '|'.    "Crear la matriz"    matrix := Matrix rows: (cantJugadores sqrt) columns: (cantJugadores sqrt).    "Recorrer los elementos y asignarlos a la matriz"    1 to: elements size - 1 do: [:i |        | row col |        row := (i - 1) // 8 + 1.  "Calcula la fila (1 a 8)"        col := (i - 1) \\ 8 + 1.   "Calcula la columna (1 a 8)"        matrix at: row column: col put: (elements at: i).    ].elements inspect! !!TableroLogico methodsFor: 'as yet unclassified' stamp: '1/23/2025 18:07' prior: 237865!crearMatrizTemas: cantJugadores| file contents elements matrix matrixSize |"Abre el archivo y lee su contenido"file := FileSystem workingDirectory / 'assets' / 'temas.txt'.contents := file readStreamDo: [ :stream | stream contents ]."Divide el contenido del archivo en elementos usando '|' como delimitador"elements := contents substrings: '|'."Crear la matriz"matrixSize := cantJugadores sqrt.matrix := Matrix rows: matrixSize columns: matrixSize."Recorrer los elementos y asignarlos a la matriz"1 to: (matrixSize * matrixSize) do: [:i |    | row col |    row := (i - 1) // matrixSize + 1.  "Calcula la fila"    col := (i - 1) \\ matrixSize + 1.   "Calcula la columna"    (i <= elements size) ifTrue: [        matrix at: row column: col put: (elements at: i).    ] ifFalse: [        matrix at: row column: col put: nil. "O algún valor por defecto"    ].].elements inspect.! !!TableroLogico methodsFor: 'as yet unclassified' stamp: '1/23/2025 18:08' prior: 239575!crearMatrizTemas: cantJugadores| file contents elements matrix matrixSize |"Abre el archivo y lee su contenido"file := FileSystem workingDirectory / 'assets' / 'temas.txt'.contents := file readStreamDo: [ :stream | stream contents ]."Divide el contenido del archivo en elementos usando '|' como delimitador"elements := contents substrings: '|'."Crear la matriz"matrixSize := cantJugadores sqrt.matrix := Matrix rows: matrixSize columns: matrixSize."Recorrer los elementos y asignarlos a la matriz"1 to: (matrixSize * matrixSize) do: [:i |    | row col |    row := (i - 1) // matrixSize + 1.  "Calcula la fila"    col := (i - 1) \\ matrixSize + 1.   "Calcula la columna"    (i <= elements size) ifTrue: [        matrix at: row column: col put: (elements at: i).    ] ifFalse: [        matrix at: row column: col put: nil. "O algún valor por defecto"    ].].matrix inspect.elements inspect.! !!TableroLogico methodsFor: 'as yet unclassified' stamp: '1/23/2025 18:09' prior: 241559!crearMatrizTemas: cantJugadores| file contents elements matrix matrixSize |"Abre el archivo y lee su contenido"file := FileSystem workingDirectory / 'assets' / 'temas.txt'.contents := file readStreamDo: [ :stream | stream contents ]."Divide el contenido del archivo en elementos usando '|' como delimitador"elements := contents substrings: '|'.elements := elements shuffled."Crear la matriz"matrixSize := cantJugadores sqrt.matrix := Matrix rows: matrixSize columns: matrixSize."Recorrer los elementos y asignarlos a la matriz"1 to: (matrixSize * matrixSize) do: [:i |    | row col |    row := (i - 1) // matrixSize + 1.  "Calcula la fila"    col := (i - 1) \\ matrixSize + 1.   "Calcula la columna"    (i <= elements size) ifTrue: [        matrix at: row column: col put: (elements at: i).    ] ifFalse: [        matrix at: row column: 