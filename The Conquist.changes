lements shuffled.    "Crear la matriz"    matrix := Matrix rows: (cantJugadores sqrt) columns: (cantJugadores sqrt).    "Recorrer los elementos y asignarlos a la matriz"    1 to: elements size do: [:i |        | row col |        row := (i - 1) // 8 + 1.  "Calcula la fila (1 a 8)"        col := (i - 1) \\ 8 + 1.   "Calcula la columna (1 a 8)"        matrix at: row column: col put: (elements at: i).    ].elements inspect.! !!Juego methodsFor: 'as yet unclassified' stamp: '1/23/2025 17:39' prior: 123101!obtenerCantJugadores    | flag MatrizTemas|    flag := false.    "Solicitar la cantidad de NPCs"    [ flag not ] whileTrue: [        CantNPC := (UIManager default request: '¿Cuántos participantes hay?') asNumber.        (((CantNPC sqrt) \\ 2) = 0)            ifTrue: [ flag := true ]            ifFalse: [ UIManager default inform: 'Valor inválido' ].    ].    "Solicitar la cantidad de jugadores humanos"    CantJugadores := (UIManager default request: '¿Cuántos participantes humanos habrá?') asNumber.MatrizTemas := TableroLogico new.MatrizTemas crearMatrizTemas: CantNPC.MatrizTemas inspect.! !!Juego methodsFor: 'as yet unclassified' stamp: '1/23/2025 17:40' prior: 206253!obtenerCantJugadores    | flag MatrizTemas|    flag := false.    "Solicitar la cantidad de NPCs"    [ flag not ] whileTrue: [        CantNPC := (UIManager default request: '¿Cuántos participantes hay?') asNumber.        ((CantNPC sqrt isInteger and: [CantNPC sqrt \\ 2 = 0]))            ifTrue: [ flag := true ]            ifFalse: [ UIManager default inform: 'Valor inválido' ].    ].    "Solicitar la cantidad de jugadores humanos"    CantJugadores := (UIManager default request: '¿Cuántos participantes humanos habrá?') asNumber.MatrizTemas := TableroLogico new.MatrizTemas crearMatrizTemas: CantNPC.MatrizTemas inspect.! !!Juego methodsFor: 'as yet unclassified' stamp: '1/23/2025 17:42' prior: 207655!obtenerCantJugadores    | flag MatrizTemas|    flag := false.    "Solicitar la cantidad de NPCs"    [ flag not ] whileTrue: [        CantNPC := (UIManager default request: '¿Cuántos participantes hay?') asNumber.        (CantNPC sqrt isInteger )            ifTrue: [ flag := true ]            ifFalse: [ UIManager default inform: 'Valor inválido' ].    ].    "Solicitar la cantidad de jugadores humanos"    CantJugadores := (UIManager default request: '¿Cuántos participantes humanos habrá?') asNumber.MatrizTemas := TableroLogico new.MatrizTemas crearMatrizTemas: CantNPC.MatrizTemas inspect.! !!TableroLogico methodsFor: 'as yet unclassified' stamp: '1/23/2025 17:43' prior: 204505!crearMatrizTemas: cantJugadores| file contents elements matrix |"Abre el archivo y lee su contenido"file := FileSystem workingDirectory / 'assets' / 'temas.txt'.contents := file readStreamDo: [ :stream | stream contents ]."Divide el contenido del archivo en elementos usando '|' como delimitador"elements := contents substrings: '|'.elements := elements shuffled.    "Crear la matriz"    matrix := Matrix rows: (cantJugadores sqrt) columns: (cantJugadores sqrt).    "Recorrer los elementos y asignarlos a la matriz"    1 to: elements size do: [:i |        | row col |        row := (i - 1) // (cantJugadores sqrt) + 1.  "Calcula la fila (1 a 8)"        col := (i - 1) \\ (cantJugadores ) + 1.   "Calcula la columna (1 a 8)"        matrix at: row column: col put: (elements at: i).    ].elements inspect.! !!TableroLogico methodsFor: 'as yet unclassified' stamp: '1/23/2025 17:46' prior: 210527!crearMatrizTemas: cantJugadores| file contents elements matrix |"Abre el archivo y lee su contenido"file := FileSystem workingDirectory / 'assets' / 'temas.txt'.contents := file readStreamDo: [ :stream | stream contents ]."Divide el contenido del archivo en elementos usando '|' como delimitador"elements := contents substrings: '|'.elements := elements shuffled.elements := elements removeAllFrom: cantJugadores.    "Crear la matriz"