irst = posJugador first - 1 and: [ posMorph second = posJugador second + 1 ]) or:     [ (posMorph first = posJugador first - 1 and: [ posMorph second = posJugador second - 1 ]) ] ])         ifTrue: [            valido := true.            Transcript show: 'La jugada es válida'; cr.        ].        Transcript show: 'La jugada es: ', valido asString; cr.    ^ valido.! !!Juego class methodsFor: 'as yet unclassified' stamp: '2/8/2025 20:04' prior: 980231!jugadaValida: cantNPC nombreJugador: nombreJugador labelMorph: labelMorph| filas columnas valido posJugador posMorph |        filas := cantNPC sqrt ceiling.    columnas := filas.    valido := false.        "Inicializar posiciones con valores fuera de rango"    posJugador := #(0 0).    posMorph := #(0 0).        "Buscar posición del jugador"    1 to: filas do: [ :fila |        1 to: columnas do: [ :columna |            (((TableroLogico matrizTableroLógico at: fila column: columna) nombre) = nombreJugador) ifTrue: [                posJugador := {fila. columna}.            ].        ].    ].        (posJugador = #(0 0)) ifTrue: [        Transcript show: 'El jugador no fue encontrado'; cr.        ^ false.    ].        "Buscar posición del Morph"    1 to: filas do: [ :fila |        1 to: columnas do: [ :columna |            (((TableroLogico matrizDeMorphs at: fila column: columna) tema) = labelMorph) ifTrue: [                posMorph := {fila. columna}.            ].        ].    ].        (posMorph = #(0 0)) ifTrue: [        Transcript show: 'El Morph no fue encontrado'; cr.        ^ false.    ].        "Validar si el movimiento es válido (diagonal arriba/abajo)"    ((posMorph first = posJugador first + 1 and: [ posMorph second = posJugador second + 1 ]) or:     [ (posMorph first = posJugador first - 1 and: [ posMorph second = posJugador second + 1 ]) or:     [ (posMorph first = posJugador first - 1 and: [ posMorph second = posJugador second - 1 ]) ] ])         ifTrue: [