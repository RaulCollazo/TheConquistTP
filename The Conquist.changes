tonMorph borderColor: Color black.buttonMorph on: #mouseUp send: #value to: [ Transcript show: 'Botón clickeado'; cr ].labelMorph := StringMorph new.labelMorph contents: label.labelMorph position: (buttonMorph bounds center - (labelMorph extent / 2))."Agregar la etiqueta al botón"buttonMorph addMorph: labelMorph.self morph: buttonMorph.! !!TableroLogico methodsFor: 'nil' stamp: '1/31/2025 21:16'!dibujarTablero|Casilla fila columna|fila := 1.columna := 1.1 to: (Juego cantNPC) do:[	Casilla := TableroLogico matrizDeMorphs at: fila column: columna.  	]! !!TableroLogico methodsFor: 'as yet unclassified' stamp: '1/31/2025 21:17' prior: 810971!dibujarTablero|Casilla fila columna|fila := 1.columna := 1.1 to: (Juego cantNPC) do:[	Casilla := TableroLogico matrizDeMorphs at: fila column: columna.  	]! !TableroLogico removeSelector: #dibujarTablero!!TableroLogico class methodsFor: 'nil' stamp: '1/31/2025 21:23'!dibujarTablero|Casilla fila columna|fila := 0.columna := 1.1 to: (Juego cantNPC) do:[:i|	fila := fila + 1.	Casilla := TableroLogico matrizDeMorphs at: fila column: columna.	(fila = (Juego cantNPC sqrt)) ifTrue: [fila := 1. columna := columna + 1].	Juego imagenMorph addMorph: Casilla.	Casilla position: (10*i)@(10*i).	]! !!TableroLogico class methodsFor: 'as yet unclassified' stamp: '1/31/2025 21:24'!dibujarTablero: imagenMorph|Casilla fila columna|fila := 0.columna := 1.1 to: (Juego cantNPC) do:[:i|	fila := fila + 1.	Casilla := TableroLogico matrizDeMorphs at: fila column: columna.	(fila = (Juego cantNPC sqrt)) ifTrue: [fila := 1. columna := columna + 1].	imagenMorph addMorph: Casilla.	Casilla position: (10*i)@(10*i).	]! !!TableroLogico class methodsFor: 'as yet unclassified' stamp: '1/31/2025 21:24'!dibujarTablero: imagenMorph cantNPC: cantNPC|temaCasilla fila columna|fila := 0.columna := 1.1 to: cantNPC do:[:i|	fila := fila + 1.	temaCasilla := TableroLogico matrizDeMorphs at: fila column: columna.	(fila = (Juego cantNPC sqrt)) ifTrue: [fila := 1. columna := columna + 1].	imagenMorph addMorph: Casilla.	Casilla position: (10*i)@(10*i).	]! !!TableroLogico class methodsFor: 'as yet unclassified' stamp: '1/31/2025 21:25' prior: 813713!dibujarTablero: imagenMorph cantNPC: cantNPC|temaCasilla fila columna|fila := 0.columna := 1.1 to: cantNPC do:[:i|	fila := fila + 1.	temaCasilla := TableroLogico matrizDeMorphs at: fila column: columna.	(fila = ( cantNPC sqrt)) ifTrue: [fila := 1. columna := columna + 1].	imagenMorph addMorph: Casilla.	Casilla position: (10*i)@(10*i).	]! !!TableroLogico class methodsFor: 'as yet unclassified' stamp: '1/31/2025 21:25' prior: 814619!dibujarTablero: imagenMorph cantNPC: cantNPC|temaCasilla fila columna|fila := 0.columna := 1.1 to: cantNPC do:[:i|	fila := fila + 1.	temaCasilla := TableroLogico matrizDeMorphs at: fila column: columna.	(fila = (cantNPC sqrt)) ifTrue: [fila := 1. columna := columna + 1].	imagenMorph addMorph: Casilla.	Casilla position: (10*i)@(10*i).	]! !!TableroLogico class methodsFor: 'as yet unclassified' stamp: '1/31/2025 21:25' prior: 815515!dibujarTablero: imagenMorph cantNPC: cantNPC|temaCasilla fila columna|fila := 0.columna := 1.1 to: cantNPC do:[:i|	fila := fila + 1.	temaCasilla := TableroLogico matrizDeMorphs at: fila column: columna.	(fila = (cantNPC sqrt)) ifTrue: [fila := 1. columna := columna + 1].	imagenMorph addMorph: Casilla.	temaCasilla position: (10*i)@(10*i).	]! !!Juego methodsFor: 'as yet unclassified' stamp: '1/31/2025 21:26' prior: 775479!dibujarFondoTablero|imagen|imagen := Form fromFileNamed: FileSystem workingDirectory / 'assets/backgrounds/background-table.jpg'.imagenMorph removeAllMorphs.imagenMorph image: imagen.! !!Juego methodsFor: 'as yet unclassified' stamp: '1/31/2025 21:27' prior: 817283!dibujarFondoTablero|imagen|imagen := Form fromFileNamed: FileSystem workingDirectory / 'assets/backgrounds/background-table.jpg'.imagenMorph removeAllMorphs.imagenMorph image: imagen.TableroLogico dibujarTablero: imagenMorph cantNPC: CantNPC! !!Juego methodsFor: 'as yet unclassified' stamp: '1/31/2025 21:27' prior: 817829!dibujarFondoTablero|imagen|imagen := Form fromFileNamed: FileSystem workingDirectory / 'assets/backgrounds/background-table.jpg'.imagenMorph removeAllMorphs.imagenMorph image: imagen.TableroLogico dibujarTablero: imagenMorph cantNPC: CantNPC.! !!TableroLogico class methodsFor: 'as yet unclassified' stamp: '1/31/2025 21:31' prior: 816409!dibujarTablero: imagenMorph cantNPC: cantNPC| temaCasilla fila columna |fila := 1.columna := 1.1 to: cantNPC do: [:i |    temaCasilla := TableroLogico matrizDeMorphs at: fila column: columna.    imagenMorph addMorph: temaCasilla.    temaCasilla position: (columna * 100) @ (fila * 100). "Ajusta la posición según sea necesario"    fila := fila + 1.    (fila > (cantNPC sqrt) ceiling) ifTrue: [        fila := 1.        columna := columna + 1.    ].]! !----SNAPSHOT----2025-01-31T21:33:13.823-03:00 The Conquist.image priorSource: 402823!----SNAPSHOT----2025-01-31T21:33:13.86-03:00 The Conquist.image priorSource: 410059!!Juego methodsFor: 'as yet unclassified' stamp: '1/31/2025 21:33' prior: 248073!dibujarFondo    | imagen imagenMorph scrollPane boton1 boton2 |        "Cargar la imagen de fondo"    imagen := Form fromFileNamed: FileSystem workingDirectory / 'assets/backgrounds/background.png'.        "Crear ImageMorph para la imagen de fondo"    imagenMorph := ImageMorph new.    imagenMorph image: imagen.    imagenMorph position: 0@0. "Asegurarse de que la imagen de fondo esté en la esquina superior izquierda"    imagenMorph extent: imagen extent. "Ajustar la extensión del ImageMorph al tamaño de la imagen"        "Crear un ScrollPane y agregar el ImageMorph"    scrollPane := ScrollPane new.    scrollPane scroller addMorph: imagenMorph.    scrollPane extent: 800@600. "Establecer la extensión del ScrollPane, ajusta según sea necesario"        "Crear el botón 1"    boton1 := SimpleButtonMorph new.    boton1 label: 'Nuevo Juego'. "Definir el texto del botón"    boton1 target: self. "Definir el objetivo de la acción como la instancia actual"    boton1 actionSelector: #obtenerCantJugadores. "Definir el método a llamar cuando se presiona el botón"    boton1 extent: 150@50.    "Posicionar el botón 1 en el centro de la imagen"    boton1 position: (scrollPane width // 2 - (boton1 width // 2)) @ (scrollPane height // 2 - (boton1 height // 2) + 120).    "Crear el botón 2"    boton2 := SimpleButtonMorph new.    boton2 label: 'Salir'. "Definir el texto del botón"    boton2 target: self. "Definir el objetivo de la acción como la instancia actual"    boton2 actionSelector: #borrarVentanasLabeledParticular. "Definir el método a llamar cuando se presiona el botón"    boton2 extent: 120@50.    "Posicionar el botón 2 debajo del botón 1"    boton2 position: (scrollPane width // 2 - (boton2 width // 2))  @ (scrollPane height // 2 - (boton2 height // 2) + 220).        "Agregar los botones al ScrollPane"    scrollPane addMorph: boton1.    scrollPane addMorph: boton2.    "Abrir el ScrollPane en el mundo"    scrollPane openInWindowLabeled: 'TheConquist'.! !!Juego methodsFor: 'as yet unclassified' stamp: '1/31/2025 21:33' prior: 820629!dibujarFondo    | imagen  boton1 boton2 |        "Cargar la imagen de fondo"    imagen := Form fromFileNamed: FileSystem workingDirectory / 'assets/backgrounds/background.png'.        "Crear ImageMorph para la imagen de fondo"    imagenMorph := ImageMorph new.    imagenMorph image: imagen.    imagenMorph position: 0@0. "Asegurarse de que la imagen de fondo esté en la esquina superior izquierda"        "Crear el botón 1"    boton1 := SimpleButtonMorph new.    boton1 label: 'Nuevo Juego'. "Definir el texto del botón"    boton1 target: self. "Definir el objetivo de la acción como la instancia actual"    boton1 actionSelector: #obtenerCantJugadores. "Definir el método a llamar cuando se presiona el botón"    boton1 extent: 150@50.    "Posicionar el botón 1 en el centro de la imagen"    boton1 position: (imagenMorph width // 2 - (boton1 width // 2)) @ (imagenMorph height // 2 - (boton1 height // 2) + 120).    "Crear el botón 2"    boton2 := SimpleButtonMorph new.    boton2 label: 'Salir'. "Definir el texto del botón"    boton2 target: self. "Definir el objetivo de la acción como la instancia actual"    boton2 actionSelector: #borrarVentanasLabeledParticular. "Definir el método a llamar cuando se presiona el botón"    boton2 extent: 120@50.    "Posicionar el botón 2 debajo del botón 1"    boton2 position: (imagenMorph width // 2 - (boton2 width // 2))  @ (imagenMorph height // 2 - (boton2 height // 2) + 220).        "Agregar los botones al ImageMorph"    imagenMorph addMorph: boton1.    imagenMorph addMorph: boton2.    "Abrir el ImageMorph en el mundo"    imagenMorph openInWindowLabeled: 'TheConquist'.! !!Casilla methodsFor: 'as yet unclassified' stamp: '1/31/2025 21:36' prior: 809759!crearCasilla: x and: y label: label|buttonMorph labelMorph|buttonMorph := Morph new.buttonMorph bounds: (50@50 extent: 50@50).buttonMorph color: Color random.buttonMorph borderWidth: 2.buttonMorph borderColor: Color black.buttonMorph on: #mouseUp send: #value to: [ Transcript show: 'Botón clickeado'; cr ].labelMorph := StringMorph new.labelMorph contents: label.labelMorph position: (buttonMorph bounds center - (labelMorph extent / 2))."Agregar la etiqueta al botón"buttonMorph addMorph: labelMorph.self morph: buttonMorph.! !!TableroLogico class methodsFor: 'as yet unclassified' stamp: '1/31/2025 21:37' prior: 819183!dibujarTablero: imagenMorph cantNPC: cantNPC| temaCasilla fila columna spacing |fila := 1.columna := 1.spacing := 10. "Espacio entre los morphs"1 to: cantNPC do: [:i |    temaCasilla := TableroLogico matrizDeMorphs at: fila column: columna.    imagenMorph addMorph: temaCasilla.    temaCasilla position: ((columna - 1) * (50 + spacing)) @ ((fila - 1) * (50 + spacing)). "Ajusta la posición según el tamaño y el espacio"    fila := fila + 1.    (fila > (cantNPC sqrt) ceiling) ifTrue: [        fila := 1.        columna := columna + 1.    ].]! !!TableroLogico class methodsFor: 'as yet unclassified' stamp: '1/31/2025 21:37' prior: 829647!dibujarTablero: imagenMorph cantNPC: cantNPC| temaCasilla fila columna |fila := 1.columna := 1.1 to: cantNPC do: [:i |    temaCasilla := TableroLogico matrizDeMorphs at: fila column: columna.    imagenMorph addMorph: temaCasilla.    temaCasilla position: (columna * 100) @ (fila * 100). "Ajusta la posición según sea necesario"    fila := fila + 1.    (fila > (cantNPC sqrt) ceiling) ifTrue: [        fila := 1.        columna := columna + 1.    ].]! !!TableroLogico class methodsFor: 'as yet unclassified' stamp: '1/31/2025 21:37' prior: 830963!dibujarTablero: imagenMorph cantNPC: cantNPC| temaCasilla fila columna spacing morphSize |fila := 1.columna := 1.spacing := 10. "Espacio entre los morphs"morphSize := 50. "Tamaño de cada morph"1 to: cantNPC do: [:i |    "Obtener el morph correspondiente de la matriz de morphs"    temaCasilla := TableroLogico matrizDeMorphs at: fila column: columna.        "Agregar el morph al imagenMorph"    imagenMorph addMorph: temaCasilla.        "Calcular la posición del morph"    temaCasilla position: ((columna - 1) * (morphSize + spacing)) @ ((fila - 1) * (morphSize + spacing)).        "Aumentar la fila"    fila := fila + 1.        "Si la fila excede el límite, reiniciar fila y aumentar columna"    (fila > (cantNPC sqrt) ceiling) ifTrue: [        fila := 1.        columna := columna + 1.    ].]! !!TableroLogico class methodsFor: 'as yet unclassified' stamp: '1/31/2025 21:38' prior: 832091!dibujarTablero: imagenMorph cantNPC: cantNPC| temaCasilla fila columna |fila := 1.columna := 1.1 to: cantNPC do: [:i |    temaCasilla := TableroLogico matrizDeMorphs at: fila column: columna.    imagenMorph addMorph: temaCasilla.    temaCasilla position: (columna * 100) @ (fila * 100). "Ajusta la posición según sea necesario"    fila := fila + 1.    (fila > (cantNPC sqrt) ceiling) ifTrue: [        fila := 1.        columna := columna + 1.    ].]! !!TableroLogico class methodsFor: 'as yet unclassified' stamp: '1/31/2025 21:39' prior: 833931!dibujarTablero: imagenMorph cantNPC: cantNPC| temaCasilla fila columna spacing morphSize |fila := 1.columna := 1.spacing := 10. "Espacio entre los morphs"morphSize := 50. "Tamaño de cada morph"1 to: cantNPC do: [:i |    "Obtener el morph correspondiente de la matriz de morphs"    temaCasilla := TableroLogico matrizDeMorphs at: fila column: columna.        "Agregar el morph al imagenMorph"    imagenMorph addMorph: temaCasilla.        "Calcular la posición del morph"    temaCasilla position: ((columna - 1) * (morphSize + spacing)) @ ((fila - 1) * (morphSize + spacing)).        "Aumentar la fila"    fila := fila + 1.        "Si la fila excede el límite, reiniciar fila y aumentar columna"    (fila > (cantNPC sqrt) ceiling) ifTrue: [        fila := 1.        columna := columna + 1.    ].]! !!TableroLogico class methodsFor: 'as yet unclassified' stamp: '1/31/2025 21:39' prior: 835059!dibujarTablero: imagenMorph cantNPC: cantNPC| temaCasilla fila columna |fila := 1.columna := 1.1 to: cantNPC do: [:i |    temaCasilla := TableroLogico matrizDeMorphs at: fila column: columna.    imagenMorph addMorph: temaCasilla.    temaCasilla position: (columna * 150) @ (fila * 150). "Ajusta la posición según sea necesario"    fila := fila + 1.    (fila > (cantNPC sqrt) ceiling) ifTrue: [        fila := 1.        columna := columna + 1.    ].]! !!TableroLogico class methodsFor: 'as yet unclassified' stamp: '1/31/2025 21:44' prior: 836899!dibujarTablero: imagenMorph cantNPC: cantNPC| temaCasilla fila columna |fila := 1.columna := 1.1 to: cantNPC do: [:i |    temaCasilla := TableroLogico matrizDeMorphs at: fila column: columna.    imagenMorph addMorph: temaCasilla.    temaCasilla position: (columna * 120) @ (fila * 120). "Ajusta la posición según sea necesario"    fila := fila + 1.    (fila > (cantNPC sqrt) ceiling) ifTrue: [        fila := 1.        columna := columna + 1.    ].]! !!Casilla methodsFor: 'as yet unclassified' stamp: '1/31/2025 21:44' prior: 828367!crearCasilla: x and: y label: label|buttonMorph labelMorph|buttonMorph := Morph new.buttonMorph bounds: (25@25 extent: 25@25).buttonMorph color: Color random.buttonMorph borderWidth: 2.buttonMorph borderColor: Color black.buttonMorph on: #mouseUp send: #value to: [ Transcript show: 'Botón clickeado'; cr ].labelMorph := StringMorph new.labelMorph contents: label.labelMorph position: (buttonMorph bounds center - (labelMorph extent / 2))."Agregar la etiqueta al botón"buttonMorph addMorph: labelMorph.self morph: buttonMorph.! !!TableroLogico class methodsFor: 'as yet unclassified' stamp: '1/31/2025 21:47' prior: 838027!dibujarTablero: imagenMorph cantNPC: cantNPC| temaCasilla fila columna |fila := 1.columna := 1.1 to: cantNPC do: [:i |    temaCasilla := TableroLogico matrizDeMorphs at: fila column: columna.    imagenMorph addMorph: temaCasilla.    temaCasilla position: (columna - 1 * 120) @ (fila - 1 * 120). "Ajusta la posición según sea necesario"    fila := fila + 1.    (fila > (cantNPC sqrt) ceiling) ifTrue: [        fila := 1.        columna := columna + 1.    ].]! !!TableroLogico class methodsFor: 'as yet unclassified' stamp: '1/31/2025 21:47' prior: 840411!dibujarTablero: imagenMorph cantNPC: cantNPC| temaCasilla fila columna |fila := 1.columna := 1.1 to: cantNPC do: [:i |    temaCasilla := TableroLogico matrizDeMorphs at: fila column: columna.    imagenMorph addMorph: temaCasilla.    temaCasilla position: ((columna - 1) * 120) @ ((fila - 1) * 120). "Ajusta la posición según sea necesario"    fila := fila + 1.    (fila > (cantNPC sqrt) ceiling) ifTrue: [        fila := 1.        columna := columna + 1.    ].]! !!TableroLogico class methodsFor: 'as yet unclassified' stamp: '1/31/2025 21:48' prior: 841553!dibujarTablero: imagenMorph cantNPC: cantNPC| temaCasilla fila columna |fila := 1.columna := 1.1 to: cantNPC do: [:i |    temaCasilla := TableroLogico matrizDeMorphs at: fila column: columna.    imagenMorph addMorph: temaCasilla.    temaCasilla position: (columna * 120) @ (fila * 120). "Ajusta la posición según sea necesario"    fila := fila + 1.    (fila > (cantNPC sqrt) ceiling) ifTrue: [        fila := 1.        columna := columna + 1.    ].]! !!Juego methodsFor: 'as yet unclassified' stamp: '1/31/2025 22:04' prior: 824853!dibujarFondo    | imagen boton1 boton2 imagenMorph scrollPane |    "Cargar la imagen de fondo"    imagen := Form fromFileNamed: FileSystem workingDirectory / 'assets/backgrounds/background.png'.    "Crear ImageMorph para la imagen de fondo"    imagenMorph := ImageMorph new.    imagenMorph image: imagen.    imagenMorph position: 0@0. "Asegurarse de que la imagen de fondo esté en la esquina superior izquierda"    "Crear el botón 1"    boton1 := SimpleButtonMorph new.    boton1 label: 'Nuevo Juego'. "Definir el texto del botón"    boton1 target: self. "Definir el objetivo de la acción como la instancia actual"    boton1 actionSelector: #obtenerCantJugadores. "Definir el método a llamar cuando se presiona el botón"    boton1 extent: 150@50.    "Posicionar el botón 1 en el centro de la imagen"    boton1 position: (imagenMorph width // 2 - (boton1 width // 2)) @ (imagenMorph height // 2 - (boton1 height // 2) + 120).    "Crear el botón 2"    boton2 := SimpleButtonMorph new.    boton2 label: 'Salir'. "Definir el texto del botón"    boton2 target: self. "Definir el objetivo de la acción como la instancia actual"    boton2 actionSelector: #borrarVentanasLabeledParticular. "Definir el método a llamar cuando se presiona el botón"    boton2 extent: 120@50.    "Posicionar el botón 2 debajo del botón 1"    boton2 position: (imagenMorph width // 2 - (boton2 width // 2)) @ (imagenMorph height // 2 - (boton2 height // 2) + 220).    "Agregar los botones al ImageMorph"    imagenMorph addMorph: boton1.    imagenMorph addMorph: boton2.    "Crear un ScrollPane y agregar el ImageMorph"    scrollPane := ScrollPane new.    scrollPane scroller addMorph: imagenMorph.    scrollPane extent: imagenMorph extent. "Ajustar el tamaño del ScrollPane al tamaño de la imagen"    "Abrir el ScrollPane en una ventana"    scrollPane openInWindowLabeled: 'TheConquist'.! !!Juego methodsFor: 'as yet unclassified' stamp: '1/31/2025 22:05' prior: 843801!dibujarFondo    | imagen  boton1 boton2 |        "Cargar la imagen de fondo"    imagen := Form fromFileNamed: FileSystem workingDirectory / 'assets/backgrounds/background.png'.        "Crear ImageMorph para la imagen de fondo"    imagenMorph := ImageMorph new.    imagenMorph image: imagen.    imagenMorph position: 0@0. "Asegurarse de que la imagen de fondo esté en la esquina superior izquierda"        "Crear el botón 1"    boton1 := SimpleButtonMorph new.    boton1 label: 'Nuevo Juego'. "Definir el texto del botón"    boton1 target: self. "Definir el objetivo de la acción como la instancia actual"    boton1 actionSelector: #obtenerCantJugadores. "Definir el método a llamar cuando se presiona el botón"    boton1 extent: 150@50.    "Posicionar el botón 1 en el centro de la imagen"    boton1 position: (imagenMorph width // 2 - (boton1 width // 2)) @ (imagenMorph height // 2 - (boton1 height // 2) + 120).    "Crear el botón 2"    boton2 := SimpleButtonMorph new.    boton2 label: 'Salir'. "Definir el texto del botón"    boton2 target: self. "Definir el objetivo de la acción como la instancia actual"    boton2 actionSelector: #borrarVentanasLabeledParticular. "Definir el método a llamar cuando se presiona el botón"    boton2 extent: 120@50.    "Posicionar el botón 2 debajo del botón 1"    boton2 position: (imagenMorph width // 2 - (boton2 width // 2))  @ (imagenMorph height // 2 - (boton2 height // 2) + 220).        "Agregar los botones al ImageMorph"    imagenMorph addMorph: boton1.    imagenMorph addMorph: boton2.    "Abrir el ImageMorph en el mundo"    imagenMorph openInWindowLabeled: 'TheConquist'.! !----SNAPSHOT----2025-01-31T22:05:37.049-03:00 The Conquist.image priorSource: 410146!----SNAPSHOT----2025-01-31T22:05:37.08-03:00 The Conquist.image priorSource: 425571!!Juego methodsFor: 'as yet unclassified' stamp: '1/31/2025 22:07' prior: 818491!dibujarFondoTablero    | imagen imagenMorph scrollPane |    "Cargar la imagen de fondo"    imagen := Form fromFileNamed: FileSystem workingDirectory / 'assets/backgrounds/background-table.jpg'.    "Crear ImageMorph para la imagen de fondo"    imagenMorph := ImageMorph new.    imagenMorph image: imagen.    imagenMorph position: 0@0. "Asegurarse de que la imagen de fondo esté en la esquina superior izquierda"    "Crear un ScrollPane y agregar el ImageMorph"    scrollPane := ScrollPane new.    scrollPane scroller addMorph: imagenMorph.    scrollPane extent: imagen extent. "Ajustar el tamaño del ScrollPane al tamaño de la imagen"    "Dibujar el tablero en el ImageMorph"    TableroLogico dibujarTablero: imagenMorph cantNPC: CantNPC.    "Abrir el ScrollPane en una ventana"    scrollPane openInWindowLabeled: 'TheConquist Board'.! !!Juego methodsFor: 'as yet unclassified' stamp: '1/31/2025 22:08' prior: 851653!dibujarFondoTablero    | imagen imagenMorph scrollPane |    "Cargar la imagen de fondo"    imagen := Form fromFileNamed: FileSystem workingDirectory / 'assets/backgrounds/background-table.jpg'.    "Crear ImageMorph para la imagen de fondo"    imagenMorph := ImageMorph new.    imagenMorph image: imagen.    imagenMorph position: 0@0. "Asegurarse de que la imagen de fondo esté en la esquina superior izquierda"    "Crear un ScrollPane y agregar el ImageMorph"    scrollPane := ScrollPane new.    scrollPane scroller addMorph: imagenMorph.    scrollPane extent: imagen extent. "Ajustar el tamaño del ScrollPane al tamaño de la imagen"    "Dibujar el tablero en el ImageMorph"    TableroLogico dibujarTablero: imagenMorph cantNPC: CantNPC.    "Abrir el ScrollPane en una ventana"    scrollPane openInWindowLabeled: 'TheConquist'.! !----SNAPSHOT----2025-01-31T22:09:29.893-03:00 The Conquist.image priorSource: 425658!----SNAPSHOT----2025-01-31T22:09:29.934-03:00 The Conquist.image priorSource: 427620!!Juego methodsFor: 'as yet unclassified' stamp: '1/31/2025 22:10' prior: 853535!dibujarFondoTablero    | imagen imagenMorph scrollPane ventanaExistente |    "Cargar la imagen de fondo"    imagen := Form fromFileNamed: FileSystem workingDirectory / 'assets/backgrounds/background-table.jpg'.    "Crear ImageMorph para la imagen de fondo"    imagenMorph := ImageMorph new.    imagenMorph image: imagen.    imagenMorph position: 0@0. "Asegurarse de que la imagen de fondo esté en la esquina superior izquierda"    "Crear un ScrollPane y agregar el ImageMorph"    scrollPane := ScrollPane new.    scrollPane scroller addMorph: imagenMorph.    scrollPane extent: imagen extent. "Ajustar el tamaño del ScrollPane al tamaño de la imagen"    "Dibujar el tablero en el ImageMorph"    TableroLogico dibujarTablero: imagenMorph cantNPC: CantNPC.    "Cerrar cualquier ventana existente etiquetada 'TheConquist Board'"    ventanaExistente := SystemWindow allInstances detect: [ :each | each label = 'TheConquist Board' ] ifNone: [ nil ].    ventanaExistente ifNotNil: [ ventanaExistente close ].    "Abrir el ScrollPane en una ventana"    scrollPane openInWindowLabeled: 'TheConquist Board'.! !!Juego methodsFor: 'as yet unclassified' stamp: '1/31/2025 22:11' prior: 855753!dibujarFondoTablero    | imagen imagenMorph scrollPane ventanaExistente |    "Cargar la imagen de fondo"    imagen := Form fromFileNamed: FileSystem workingDirectory / 'assets/backgrounds/background-table.jpg'.    "Crear ImageMorph para la imagen de fondo"    imagenMorph := ImageMorph new.    imagenMorph image: imagen.    imagenMorph position: 0@0. "Asegurarse de que la imagen de fondo esté en la esquina superior izquierda"    "Crear un ScrollPane y agregar el ImageMorph"    scrollPane := ScrollPane new.    scrollPane scroller addMorph: imagenMorph.    scrollPane extent: imagen extent. "Ajustar el tamaño del ScrollPane al tamaño de la imagen"    "Dibujar el tablero en el ImageMorph"    TableroLogico dibujarTablero: imagenMorph cantNPC: CantNPC.    "Cerrar cualquier ventana existente etiquetada 'TheConquist Board'"    ventanaExistente := SystemWindow allInstances detect: [ :each | each label = 'TheConquist' ] ifNone: [ nil ].    ventanaExistente ifNotNil: [ ventanaExistente close ].    "Abrir el ScrollPane en una ventana"    scrollPane openInWindowLabeled: 'TheConquist Board'.! !----SNAPSHOT----2025-01-31T22:11:55.756-03:00 The Conquist.image priorSource: 427707!----SNAPSHOT----2025-01-31T22:11:55.787-03:00 The Conquist.image priorSource: 430208!!Juego methodsFor: 'as yet unclassified' stamp: '1/31/2025 22:12' prior: 858173!dibujarFondoTablero    | imagen imagenMorph scrollPane ventanaExistente |    "Cargar la imagen de fondo"    imagen := Form fromFileNamed: FileSystem workingDirectory / 'assets/backgrounds/background-table.jpg'.    "Crear ImageMorph para la imagen de fondo"    imagenMorph := ImageMorph new.    imagenMorph image: imagen.    imagenMorph position: 0@0. "Asegurarse de que la imagen de fondo esté en la esquina superior izquierda"    "Crear un ScrollPane y agregar el ImageMorph"    scrollPane := ScrollPane new.    scrollPane scroller addMorph: imagenMorph.    scrollPane extent: (300@300). "Ajustar el tamaño del ScrollPane según sea necesario"    "Dibujar el tablero en el ImageMorph"    TableroLogico dibujarTablero: imagenMorph cantNPC: CantNPC.    "Cerrar cualquier ventana existente etiquetada 'TheConquist Board'"    ventanaExistente := SystemWindow allInstances detect: [ :each | each label = 'TheConquist' ] ifNone: [ nil ].    ventanaExistente ifNotNil: [ ventanaExistente close ].    "Abrir el ScrollPane en una ventana"    scrollPane openInWindowLabeled: 'TheConquist Board'.! !----SNAPSHOT----2025-01-31T22:13:12.883-03:00 The Conquist.image priorSource: 430295!----SNAPSHOT----2025-01-31T22:13:12.924-03:00 The Conquist.image priorSource: 431579!----SNAPSHOT----2025-01-31T22:16:29.209-03:00 The Conquist.image priorSource: 431666!----SNAPSHOT----2025-01-31T22:16:29.254-03:00 The Conquist.image priorSource: 431753!----QUIT----2025-01-31T22:16:34.116-03:00 The Conquist.image priorSource: 431840!----QUIT----2025-01-31T22:16:34.148-03:00 The Conquist.image priorSource: 431927!----QUIT/NOSAVE----2025-02-05T10:58:36.256-03:00 The Conquist.image priorSource: 432010!----QUIT/NOSAVE----2025-02-05T10:58:36.31-03:00 The Conquist.image priorSource: 432010!!Juego methodsFor: 'as yet unclassified' stamp: '2/7/2025 02:07' prior: 860929!dibujarFondoTablero    | imagen imagenMorph scrollPane ventanaExistente |    "Cargar la imagen de fondo"    imagen := Form fromFileNamed: FileSystem workingDirectory / 'assets/backgrounds/background-table.jpg'.    "Crear ImageMorph para la imagen de fondo"    imagenMorph := ImageMorph new.    imagenMorph image: imagen.    imagenMorph position: 0@0. "Asegurarse de que la imagen de fondo esté en la esquina superior izquierda"    "Crear un ScrollPane y agregar el ImageMorph"    scrollPane := ScrollPane new.    scrollPane scroller addMorph: imagenMorph.    scrollPane extent: (300@300). "Ajustar el tamaño del ScrollPane según sea necesario"    "Dibujar el tablero en el ImageMorph"    TableroLogico dibujarTablero: imagenMorph cantNPC: CantNPC.    "Cerrar cualquier ventana existente etiquetada 'TheConquist Board'"    ventanaExistente := SystemWindow allInstances detect: [ :each | each label = 'TheConquist' ] ifNone: [ nil ].    ventanaExistente ifNotNil: [ ventanaExistente close ].    "Abrir el ScrollPane en una ventana"    scrollPane openInWindowLabeled: 'TheConquist Board'.	UIManager default inform: '¡Hola!! Esta es una alerta en Pharo 12'.! !!Juego methodsFor: 'as yet unclassified' stamp: '2/7/2025 02:08' prior: 864707!dibujarFondoTablero    | imagen imagenMorph scrollPane ventanaExistente |    "Cargar la imagen de fondo"    imagen := Form fromFileNamed: FileSystem workingDirectory / 'assets/backgrounds/background-table.jpg'.    "Crear ImageMorph para la imagen de fondo"    imagenMorph := ImageMorph new.    imagenMorph image: imagen.    imagenMorph position: 0@0. "Asegurarse de que la imagen de fondo esté en la esquina superior izquierda"    "Crear un ScrollPane y agregar el ImageMorph"    scrollPane := ScrollPane new.    scrollPane scroller addMorph: imagenMorph.    scrollPane extent: (300@300). "Ajustar el tamaño del ScrollPane según sea necesario"    "Dibujar el tablero en el ImageMorph"    TableroLogico dibujarTablero: imagenMorph cantNPC: CantNPC.    "Cerrar cualquier ventana existente etiquetada 'TheConquist Board'"    ventanaExistente := SystemWindow allInstances detect: [ :each | each label = 'TheConquist' ] ifNone: [ nil ].    ventanaExistente ifNotNil: [ ventanaExistente close ].    "Abrir el ScrollPane en una ventana"    scrollPane openInWindowLabeled: 'TheConquist Board'.	UIManager default inform: 'Inicio del Juego!!'.	UIManager default inform: 'Buscando Jugador!!'.! !----QUIT/NOSAVE----2025-02-07T11:41:36.831-03:00 The Conquist.image priorSource: 432010!----QUIT/NOSAVE----2025-02-07T11:41:36.864-03:00 The Conquist.image priorSource: 432010!----QUIT/NOSAVE----2025-02-07T11:42:53.486-03:00 The Conquist.image priorSource: 432010!----QUIT/NOSAVE----2025-02-07T11:42:53.518-03:00 The Conquist.image priorSource: 43201