tents ]."Divide el contenido del archivo en elementos usando '|' como delimitador"elements := contents substrings: '|'.fila := 1.columna := 1.random := Random new.cantNPClocal := cantNPCs."La matriz tablero va a estar compuesta por el objeto jugadores, que contendrá en cada posición los datos del jugador, si es NPC o no, su tema y sus puntos"jugador := Jugador new.matrizTablero := Matrix rows: (cantJugadores sqrt) columns: (cantJugadores sqrt).1 to: cantJugadores  do: [	(cantNPClocal = 0) ifFalse:[   	(booleanValue := random next < 0.2) ifTrue: [ 		(cantNPClocal := cantNPClocal - 1).		(jugador nombre: (UIManager default request: 'Por favor ingrese el nombre del participante')).		(jugador nPC: false).		(jugador puntosProbabilidad: 0).		(jugador tema: (self matrizDeTemas at: fila column:columna)).		[ (fila = cantJugadores sqrt) ifTrue: [ fila := 0. columna := columna + 1]].		(fila := fila + 1)		 ]	 ifFalse: [ 		(jugador nombre: (elements atRandom)).		(jugador nPC: true).		(jugador puntosProbabilidad: 0).		(jugador tema: (self matrizDeTemas at: fila column:columna)).		[ (fila = cantJugadores sqrt) ifTrue: [ fila := 0. columna := columna + 1]].		(fila := fila + 1)		 ].		 ] ifTrue: [ 		(jugador nombre: (elements atRandom)).		(jugador nPC: true).		(jugador puntosProbabilidad: 0).		(jugador tema: (TableroLogico matrizDeTemas at: fila column:columna)).		[ (fila = cantJugadores sqrt) ifTrue: [ fila := 0. columna := columna + 1]].		(fila := fila + 1)]].matrizTablero inspect.! !!TableroLogico class methodsFor: 'as yet unclassified' stamp: '1/26/2025 07:28' prior: 353093!crearMatrizTablero: cantJugadores NPCs: cantNPCs| matrizTablero fila columna random cantNPClocal nombreJugador jugador file contents elements |(cantJugadores sqrt isInteger) ifFalse: [     self error: 'La cantidad de jugadores debe ser un cuadrado perfecto.' ].(cantNPCs > cantJugadores) ifTrue: [     self error: 'La cantidad de NPCs no puede ser mayor a la de juga