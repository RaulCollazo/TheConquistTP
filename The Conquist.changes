dores    | flag MatrizTemas|    flag := false.    "Solicitar la cantidad de NPCs"    [ flag not ] whileTrue: [        CantNPC := (UIManager default request: '¿Cuántos participantes hay?') asNumber.        ((CantNPC sqrt \\ 2) = 0)            ifTrue: [ flag := true ]            ifFalse: [ UIManager default inform: 'Valor inválido' ].    ].    "Solicitar la cantidad de jugadores humanos"    CantJugadores := (UIManager default request: '¿Cuántos participantes humanos habrá?') asNumber.MatrizTemas := Matrix new.MatrizTemas crearMatrizTemas: CantNPC.! !!Juego methodsFor: 'as yet unclassified' stamp: '1/23/2025 09:57' prior: 116645!obtenerCantJugadores    | flag MatrizTemas|    flag := false.    "Solicitar la cantidad de NPCs"    [ flag not ] whileTrue: [        CantNPC := (UIManager default request: '¿Cuántos participantes hay?') asNumber.        ((CantNPC sqrt \\ 2) = 0)            ifTrue: [ flag := true ]            ifFalse: [ UIManager default inform: 'Valor inválido' ].    ].    "Solicitar la cantidad de jugadores humanos"    CantJugadores := (UIManager default request: '¿Cuántos participantes humanos habrá?') asNumber.MatrizTemas := Matrix new.MatrizTemas crearMatrizTemas: CantNPC.MatrizTemas inspect.! !!Juego methodsFor: 'as yet unclassified' stamp: '1/23/2025 10:01' prior: 117987!obtenerCantJugadores    | flag MatrizTemas|    flag := false.    "Solicitar la cantidad de NPCs"    [ flag not ] whileTrue: [        CantNPC := (UIManager default request: '¿Cuántos participantes hay?') asNumber.        ((CantNPC sqrt \\ 2) = 0)            ifTrue: [ flag := true ]            ifFalse: [ UIManager default inform: 'Valor inválido' ].    ].    "Solicitar la cantidad de jugadores humanos"    CantJugadores := (UIManager default request: '¿Cuántos participantes humanos habrá?') asNumber.MatrizTemas := Matrix new.MatrizTemas crearMatrizTemas: CantNPC.MatrizTemas inspect.! !TableroLogico class removeSelector: #crearMatrizTemas:!!TableroLogico methodsFor: 'nil' stamp: '1/23/2025 10:02'!crearMatrizTemas: cantJugadores| file contents elements matrix |"Abre el archivo y lee su contenido"file := FileSystem workingDirectory / 'assets' / 'temas.txt'.contents := file readStreamDo: [ :stream | stream contents ]."Divide el contenido del archivo en elementos usando '|' como delimitador"elements := contents substrings: '|'.    "Crear la matriz"    matrix := Matrix rows: (cantJugadores sqrt) columns: (cantJugadores sqrt).    "Recorrer los elementos y asignarlos a la matriz"    1 to: elements size do: [:i |        | row col |        row := (i - 1) // 8 + 1.  "Calcula la fila (1 a 8)"        col := (i - 1) \\ 8 + 1.   "Calcula la columna (1 a 8)"        matrix at: row column: col put: (elements at: i).    ].    "Imprimir la matriz para verificar"    1 to: matrix rows do: [:rowIndex |  "Iterar sobre las filas"        1 to: matrix cols do: [:colIndex |  "Iterar sobre las columnas"            Transcript show: (matrix at: rowIndex column: colIndex); space.        ].        Transcript cr.    ].elements inspect! !!Juego methodsFor: 'as yet unclassified' stamp: '1/23/2025 10:11' prior: 119371!obtenerCantJugadores    | flag MatrizTemas|    flag := false.    "Solicitar la cantidad de NPCs"    [ flag not ] whileTrue: [        CantNPC := (UIManager default request: '¿Cuántos participantes hay?') asNumber.        ((CantNPC sqrt \\ 2) = 0)            ifTrue: [ flag := true ]            ifFalse: [ UIManager default inform: 'Valor inválido' ].    ].    "Solicitar la cantidad de jugadores humanos"    CantJugadores := (UIManager default request: '¿Cuántos participantes humanos habrá?') asNumber.MatrizTemas := TableroLogico new.MatrizTemas crearMatrizTemas: CantNPC.MatrizTemas inspect.! !----SNAPSHOT----2025-01-23T10:12:07.621-03:00 The Conquist.image priorSource: 50283!----SNAPSHOT----2025-01-23T10:12:07.651-03:00 The Conquist.image priorSource: 62167!----SNAPSHOT----2025