e: [				(tmp4 = tmp2 and: tmp5 = tmp3) ifTrue: [					tmp1						add: tmp2 @ (tmp3 - 1);						add: tmp2 - 1 @ tmp3 ] ].			(TableroLogico matrizDeTemas at: tmp4 column: tmp5)			= jugadorActual tema ifTrue: [				(tmp4 = 1 and: (1 < tmp5 and: tmp5 < tmp3)) ifTrue: [					tmp1						add: 1 @ (tmp5 - 1);						add: 1 @ (tmp5 + 1);						add: 2 @ tmp5 ] ].			(TableroLogico matrizDeTemas at: tmp4 column: tmp5)			= jugadorActual tema ifTrue: [				(tmp4 = tmp2 and: (1 < tmp5 and: tmp5 < tmp3)) ifTrue: [					tmp1						add: tmp2 @ (tmp5 - 1);						add: tmp2 @ (tmp5 + 1);						add: tmp2 - 1 @ tmp5 ] ].			(TableroLogico matrizDeTemas at: tmp4 column: tmp5)			= jugadorActual tema ifTrue: [				(tmp5 = 1 and: (1 < tmp4 and: tmp4 < tmp2)) ifTrue: [					tmp1						add: tmp4 - 1 @ 1;						add: tmp4 + 1 @ 1;						add: tmp4 @ 2 ] ].			(TableroLogico matrizDeTemas at: tmp4 column: tmp5)			= jugadorActual tema ifTrue: [				(tmp5 = tmp3 and: (1 < tmp4 and: tmp4 < tmp2)) ifTrue: [					tmp1						add: tmp4 - 1 @ tmp3;						add: tmp4 + 1 @ tmp3;						add: tmp4 @ (tmp3 - 1) ] ].			(TableroLogico matrizDeTemas at: tmp4 column: tmp5)			= jugadorActual tema ifTrue: [				((1 < tmp4 and: tmp4 < tmp2) and: (1 < tmp5 and: tmp5 < tmp3))					ifTrue: [						tmp1							add: tmp4 - 1 @ tmp5;							add: tmp4 + 1 @ tmp5;							add: tmp4 @ (tmp5 - 1);							add: tmp4 @ (tmp5 + 1) ] ] ] ].	1.	tmp1 := tmp1 atRandom.	tmp7 := tmp1 x.	tmp8 := tmp1 y.	tmp6 := TableroLogico matrizTableroLógico at: tmp7 column: tmp8.	tmp6 nPC		ifTrue: [			Transcript show: 'Duelo de bot - bot'.			tmp9 := Random new next < 0.5.			tmp9				ifTrue: [ self ganaDesafiante: jugadorActual desafiado: tmp6 ]				ifFalse: [ self ganaDesafiante: tmp6 desafiado: jugadorActual ] ]		ifFalse: [ Transcript show: 'Duelo de bots - persona' ].self flujoPrincipalTableroYaCreado .! !!Juego methodsFor: 'ManageJuego' stamp: '2/14/2025 03:07' prior: 1931223!flujoPrincipalTableroYaCreadoTableroLogico inspect.		(UIManager default confirm: 'continuar?') ifTrue:[		turnoActual := turnoActual  + 1 .        self turnoActualmente.        self obtenerJugadorActual.        self esJugadorBot.] ifFalse:[].! !----SNAPSHOT----2025-02-14T03:08:33.155-03:00 The Conquist.image priorSource: 942950!----SNAPSHOT----2025-02-14T03:08:33.269-03:00 The Conquist.image priorSource: 974274!!Juego methodsFor: 'ManageJuego' stamp: '2/14/2025 03:09' prior: 1948049!flujoPrincipalTableroYaCreadoTableroLogico inspect.		juegoActivo ifTrue:[		turnoActual := turnoActual  + 1 .        self turnoActualmente.        self obtenerJugadorActual.        self esJugadorBot.] ifFalse:[].! !!Juego methodsFor: 'ManageJuego' stamp: '2/14/2025 03:10' prior: 1766347!jugadorPersonaActivaUIManager default confirm: 'Hola'.juegoActivo := false.self flujoPrincipalTableroYaCreado.! !!Juego methodsFor: 'ManageJuego' stamp: '2/14/2025 03:11' prior: 1949637!jugadorPersonaActivaUIManager default confirm: 'Hola'.self flujoPrincipalTableroYaCreado.! !!Juego methodsFor: 'ManageJuego' stamp: '2/14/2025 03:12' prior: 1949047!flujoPrincipalTableroYaCreadoTableroLogico inspect.		turnoActual := turnoActual  + 1 .        self turnoActualmente.        self obtenerJugadorActual.        self esJugadorBot.! !----QUIT/NOSAVE----2025-02-14T03:13:55.615-03:00 The Conquist.image priorSource: 974361!----QUIT/NOSAVE----2025-02-14T03:13:55.641-03:00 The Conquist.image priorSource: 974361!----QUIT/NOSAVE----2025-02-14T03:26:42.442-03:00 The Conquist.image priorSource: 974361!----QUIT/NOSAVE----2025-02-14T03:26:42.47-03:00 The Conquist.image priorSource: 974361!!TableroLogico class methodsFor: 'CreaciónyManejodeMAtrices' stamp: '2/14/2025 03:37' prior: 1758351!crearMatrizTablero: cantJugadores NPCs: cantNPCs| matrizTablero fila columna cantNPClocal random booleanValue file contents elements jugador |file := FileSystem workingDirectory / 'assets' / 'nombresNPC.txt'.contents := file readStreamDo: [ :stream | stream contents ]."Divide el contenido del archivo en elementos usando '|' como delimitador"elements := contents substrings: '|'.elements := elements shuffled. "Mezclar los elementos"fila := 1.columna := 1.random := Random new.cantNPClocal := cantNPCs."La matriz tablero va a estar compuesta por el objeto jugadores, que contendrá en cada posición los datos del jugador, si es NPC o no, su tema y sus puntos"matrizTablero := Matrix rows: (cantJugadores sqrt ceiling) columns: (cantJugadores sqrt ceiling).1 to: cantJugadores do: [:i |    jugador := Jugador new.    (cantNPClocal > 0) ifTrue: [        cantNPClocal := cantNPClocal - 1.        jugador nombre: (UIManager default request: 'Por favor ingrese el nombre del participante').        jugador nPC: false.    ] ifFalse: [        jugador nombre: (elements atRandom).        jugador nPC: true.    ].    jugador puntosProbabilidad: 0.    jugador tema: (TableroLogico matrizDeTemas at: fila column: columna).    matrizTablero at: fila column: columna put: jugador.    (fila = matrizTablero rows) ifTrue: [        fila := 1.        columna := columna + 1.    ] ifFalse: [        fila := fila + 1.    ].].self matrizTableroLógico: matrizTablero.! !!Juego methodsFor: 'ManageJuego' stamp: '2/14/2025 03:48' prior: 1942015!simularDuelo	| posicionesValidas tableroFilas tableroColumnas cantNPC cantNPCMax fila columna casilla seleccionPosicion jugadorEnCasilla |	posicionesValidas := OrderedCollection new.	tableroFilas := self cantNPC sqrt ceiling.	tableroColumnas := self cantNPC sqrt ceiling.	cantNPC := self cantNPC.	cantNPCMax := cantNPC.	1 to: cantNPCMax do: [ :index |		fila := index - 1 // tableroColumnas + 1.		columna := index - 1 \\ tableroColumnas + 1.		(TableroLogico matrizDeTemas at: fila column: columna)		= jugadorActual tema ifTrue: [			(TableroLogico matrizDeTemas at: fila column: columna)			= jugadorActual tema ifTrue: [				(fila = 1 and: columna = 1) ifTrue: [					posicionesValidas						add: 2 @ 1;						add: 1 @ 2 ] ].			(TableroLogico matrizDeTemas at: fila column: columna)			= jugadorActual tema ifTrue: [				(fila = 1 and: columna = tableroColumnas) ifTrue: [					posicionesValidas						add: 1 @ (tableroColumnas - 1);						add: 2 @ tableroColumnas ] ].			(TableroLogico matrizDeTemas at: fila column: columna)			= jugadorActual tema ifTrue: [				(fila = tableroFilas and: columna = 1) ifTrue: [					posicionesValidas						add: tableroFilas - 1 @ 1;						add: tableroFilas @ 2 ] ].			(TableroLogico matrizDeTemas at: fila column: columna)			= jugadorActual tema ifTrue: [				(fila = tableroFilas and: columna = tableroColumnas) ifTrue: [					posicionesValidas						add: tableroFilas @ (tableroColumnas - 1);						add: tableroFilas - 1 @ tableroColumnas ] ].			(TableroLogico matrizDeTemas at: fila column: columna)			= jugadorActual tema ifTrue: [				(fila = 1 and: (1 < columna and: columna < tableroColumnas)) ifTrue: [					posicionesValidas						add: 1 @ (columna - 1);						add: 1 @ (columna + 1);						add: 2 @ columna ] ].			(TableroLogico matrizDeTemas at: fila column: columna)			= jugadorActual tema ifTrue: [				(fila = tableroFilas and: (1 < columna and: columna < tableroColumnas)) ifTrue: [					posicionesValidas						add: tableroFilas @ (columna - 1);						add: tableroFilas @ (columna + 1);						add: tableroFilas - 1 @ columna ] ].			(TableroLogico matrizDeTemas at: fila column: columna)			= jugadorActual tema ifTrue: [				(columna = 1 and: (1 < fila and: fila < tableroFilas)) ifTrue: [					posicionesValidas						add: fila - 1 @ 1;						add: fila + 1 @ 1;						add: fila @ 2 ] ].			(TableroLogico matrizDeTemas at: fila column: columna)			= jugadorActual tema ifTrue: [				(columna = tableroColumnas and: (1 < fila and: fila < tableroFilas)) ifTrue: [					posicionesValidas						add: fila - 1 @ tableroColumnas;						add: fila + 1 @ tableroColumnas;						add: fila @ (tableroColumnas - 1) ] ].			(TableroLogico matrizDeTemas at: fila column: columna)			= jugadorActual tema ifTrue: [				((1 < fila and: fila < tableroFilas) and: (1 < columna and: columna < tableroColumnas))					ifTrue: [						posicionesValidas							add: fila - 1 @ columna;							add: fila + 1 @ columna;							add: fila @ (columna - 1);							add: fila @ (columna + 1) ] ] ] ].	1.	seleccionPosicion := posicionesValidas atRandom.	fila := seleccionPosicion x.	columna := seleccionPosicion y.	jugadorEnCasilla := TableroLogico matrizTableroLógico at: fila column: columna.	jugadorEnCasilla nPC		ifTrue: [			Transcript show: 'Duelo de bot - bot'.			(Random new next < 0.5)				ifTrue: [ self ganaDesafiante: jugadorActual desafiado: jugadorEnCasilla ]				ifFalse: [ self ganaDesafiante: jugadorEnCasilla desafiado: jugadorActual ] ]		ifFalse: [ Transcript show: 'Duelo de bots - persona' ].	self flujoPrincipalTableroYaCreado.! !----QUIT/NOSAVE----2025-02-14T03:49:33.697-03:00 The Conquist.image priorSource: 974361!----QUIT/NOSAVE----2025-02-14T03:49:33.75-03:00 The Conquist.image priorSource: 974361!----QUIT/NOSAVE----2025-02-14T03:51:16.804-03:00 The Conquist.image priorSource: 974361!----QUIT/NOSAVE----2025-02-14T03:51:16.825-03:00 The Conquist.image priorSource: 974361!----SNAPSHOT----2025-02-14T04:15:04.815-03:00 The Conquist.image priorSource: 981355!----SNAPSHOT----2025-02-14T04:15:49.345-03:00 The Conquist.image priorSource: 981355!----SNAPSHOT----2025-02-14T04:15:49.369-03:00 The Conquist.image priorSource: 981442!----QUIT/NOSAVE----2025-02-14T04:15:51.617-03:00 The Conquist.image priorSource: 981529!----QUIT/NOSAVE----2025-02-14T04:15:51.646-03:00 The Conquist.image priorSource: 981529!----QUIT/NOSAVE----2025-02-15T01:23:40.991-03:00 The Conquist.image priorSource: 981529!----QUIT/NOSAVE----2025-02-15T01:23:41.028-03:00 The Conquist.image priorSource: 981529!----QUIT/NOSAVE----2025-02-15T01:24:51.23-03:00 The Conquist.image priorSource: 981529!