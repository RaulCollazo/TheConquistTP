Jugadores NPCs: 3.! !----QUIT/NOSAVE----2025-01-26T16:37:26.333-03:00 The Conquist.image priorSource: 197167!----QUIT/NOSAVE----2025-01-26T16:37:26.352-03:00 The Conquist.image priorSource: 197167!!Juego methodsFor: 'as yet unclassified' stamp: '1/26/2025 16:38' prior: 339683!obtenerCantJugadores    | flag MatrizTemas|    flag := false.    "Solicitar la cantidad de NPCs"    [ flag not ] whileTrue: [        CantNPC := (UIManager default request: '¿Cuántos participantes hay?') asNumber.        ((CantNPC sqrt isInteger))             ifTrue: [ flag := true ]            ifFalse: [ UIManager default inform: 'Valor inválido' ].    ].    "Solicitar la cantidad de jugadores humanos"    CantJugadores := (UIManager default request: '¿Cuántos participantes humanos habrá?') asNumber.MatrizTemas := TableroLogico crearMatrizTemas: CantNPC.MatrizTemas crearMatrizTablero: CantJugadores NPCs: CantNPC. self dibujarFondoTablero .! !!Juego methodsFor: 'as yet unclassified' stamp: '1/26/2025 16:39' prior: 426357!obtenerCantJugadores    | flag MatrizTemas|    flag := false.    "Solicitar la cantidad de NPCs"    [ flag not ] whileTrue: [        CantNPC := (UIManager default request: '¿Cuántos participantes hay?') asNumber.        ((CantNPC sqrt isInteger))             ifTrue: [ flag := true ]            ifFalse: [ UIManager default inform: 'Valor inválido' ].    ].    "Solicitar la cantidad de jugadores humanos"    CantJugadores := (UIManager default request: '¿Cuántos participantes humanos habrá?') asNumber.MatrizTemas := TableroLogico crearMatrizTemas: CantJugadores .MatrizTemas crearMatrizTablero: CantJugadores NPCs: CantNPC. self dibujarFondoTablero .! !----QUIT/NOSAVE----2025-01-26T16:43:56.614-03:00 The Conquist.image priorSource: 197167!----QUIT/NOSAVE----2025-01-26T16:43:56.635-03:00 The Conquist.image priorSource: 197167!!Juego methodsFor: 'as yet unclassified' stamp: '1/26/2025 16:45' prior: 339683!obtenerCantJugadores    | flag Matriz