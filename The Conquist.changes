methodsFor: 'as yet unclassified' stamp: '1/26/2025 16:21' prior: 339683!obtenerCantJugadores    | flag MatrizTemas|    flag := false.    "Solicitar la cantidad de NPCs"    [ flag not ] whileTrue: [        CantNPC := (UIManager default request: '¿Cuántos participantes hay?') asNumber.        ((CantNPC sqrt isInteger))             ifTrue: [ flag := true ]            ifFalse: [ UIManager default inform: 'Valor inválido' ].    ].    "Solicitar la cantidad de jugadores humanos"    CantJugadores := (UIManager default request: '¿Cuántos participantes humanos habrá?') asNumber.MatrizTemas := TableroLogico crearMatrizTemas: CantJugadores.TableroLogico matrizDeTemas inspect.self dibujarFondoTablero .! !!Juego methodsFor: 'as yet unclassified' stamp: '1/26/2025 16:23' prior: 397825!obtenerCantJugadores    | flag MatrizTemas|    flag := false.    "Solicitar la cantidad de NPCs"    [ flag not ] whileTrue: [        CantNPC := (UIManager default request: '¿Cuántos participantes hay?') asNumber.        ((CantNPC sqrt isInteger))             ifTrue: [ flag := true ]            ifFalse: [ UIManager default inform: 'Valor inválido' ].    ].    "Solicitar la cantidad de jugadores humanos"    CantJugadores := (UIManager default request: '¿Cuántos participantes humanos habrá?') asNumber.MatrizTemas := TableroLogico crearMatrizTemas: CantJugadores.TableroLogico crearMatrizTablero: CantJugadores NPCs: CantNPC.self dibujarFondoTablero .! !----QUIT/NOSAVE----2025-01-26T16:24:40.273-03:00 The Conquist.image priorSource: 197167!----QUIT/NOSAVE----2025-01-26T16:24:40.292-03:00 The Conquist.image priorSource: 197167!Object class << TableroLogico class	slots: { #MatrizDeTemas. #MatrizTablero }!!TableroLogico class methodsFor: 'accessing' stamp: '1/26/2025 16:25'!matrizTablero	^ MatrizTablero! !!TableroLogico class methodsFor: 'accessing' stamp: '1/26/2025 16:25'!matrizTablero: anObject	MatrizTablero := anObject! !!TableroLogico class methodsFor: '