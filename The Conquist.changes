dores    | flag MatrizTemas|    flag := false.    "Solicitar la cantidad de NPCs"    [ flag not ] whileTrue: [        CantNPC := (UIManager default request: '¿Cuántos participantes hay?') asNumber.        ((CantNPC sqrt \\ 2) = 0)            ifTrue: [ flag := true ]            ifFalse: [ UIManager default inform: 'Valor inválido' ].    ].    "Solicitar la cantidad de jugadores humanos"    CantJugadores := (UIManager default request: '¿Cuántos participantes humanos habrá?') asNumber.MatrizTemas := Matrix new.MatrizTemas crearMatrizTemas: CantNPC.! !!Juego methodsFor: 'as yet unclassified' stamp: '1/23/2025 09:57' prior: 116645!obtenerCantJugadores    | flag MatrizTemas|    flag := false.    "Solicitar la cantidad de NPCs"    [ flag not ] whileTrue: [        CantNPC := (UIManager default request: '¿Cuántos participantes hay?') asNumber.        ((CantNPC sqrt \\ 2) = 0)            ifTrue: [ flag := true ]            ifFalse: [ UIManager default inform: 'Valor inválido' ].    ].    "Solicitar la cantidad de jugadores humanos"    CantJugadores := (UIManager default request: '¿Cuántos participantes humanos habrá?') asNumber.MatrizTemas := Matrix new.MatrizTemas crearMatrizTemas: CantNPC.MatrizTemas inspect.! !!Juego methodsFor: 'as yet unclassified' stamp: '1/23/2025 10:01' prior: 117987!obtenerCantJugadores    | flag MatrizTemas|    flag := false.    "Solicitar la cantidad de NPCs"    [ flag not ] whileTrue: [        CantNPC := (UIManager default request: '¿Cuántos participantes hay?') asNumber.        ((CantNPC sqrt \\ 2) = 0)            ifTrue: [ flag := true ]            ifFalse: [ UIManager default inform: 'Valor inválido' ].    ].    "Solicitar la cantidad de jugadores humanos"    CantJugadores := (UIManager default request: '¿Cuántos participantes humanos habrá?') asNumber.MatrizTemas := Matrix new.MatrizTemas crearMatrizTemas: CantNPC.MatrizTemas inspect.! !TableroLogico class removeSelector: #crearMatrizTemas:!!TableroLogico methodsFor: 'nil' stamp: '1/23/2025 10:02'!crearMatrizTemas: cantJugadores| file contents elements matrix |"Abre el archivo y lee su contenido"file := FileSystem workingDirectory / 'assets' / 'temas.txt'.contents := file readStreamDo: [ :stream | stream contents ]."Divide el contenido del archivo en elementos usando '|' como delimitador"elements := contents substrings: '|'.    "Crear la matriz"    matrix := Matrix rows: (cantJugadores sqrt) columns: (cantJugadores sqrt).    "Recorrer los elementos y asignarlos a la matriz"    1 to: elements size do: [:i |        | row col |        row := (i - 1) // 8 + 1.  "Calcula la fila (1 a 8)"        col := (i - 1) \\ 8 + 1.   "Calcula la columna (1 a 8)"        matrix at: row column: col put: (elements at: i).    ].    "Imprimir la matriz para verificar"    1 to: matrix rows do: [:rowIndex |  "Iterar sobre las filas"        1 to: matrix cols do: [:colIndex |  "Iterar sobre las columnas"            Transcript show: (matrix at: rowIndex column: colIndex); space.        ].        Transcript cr.    ].elements inspect! !!Juego methodsFor: 'as yet unclassified' stamp: '1/23/2025 10:11' prior: 119371!obtenerCantJugadores    | flag MatrizTemas|    flag := false.    "Solicitar la cantidad de NPCs"    [ flag not ] whileTrue: [        CantNPC := (UIManager default request: '¿Cuántos participantes hay?') asNumber.        ((CantNPC sqrt \\ 2) = 0)            ifTrue: [ flag := true ]            ifFalse: [ UIManager default inform: 'Valor inválido' ].    ].    "Solicitar la cantidad de jugadores humanos"    CantJugadores := (UIManager default request: '¿Cuántos participantes humanos habrá?') asNumber.MatrizTemas := TableroLogico new.MatrizTemas crearMatrizTemas: CantNPC.MatrizTemas inspect.! !----SNAPSHOT----2025-01-23T10:12:07.621-03:00 The Conquist.image priorSource: 50283!----SNAPSHOT----2025-01-23T10:12:07.651-03:00 The Conquist.image priorSource: 62167!----SNAPSHOT----2025-01-23T10:15:13.854-03:00 The Conquist.image priorSource: 62253!----SNAPSHOT----2025-01-23T10:15:13.886-03:00 The Conquist.image priorSource: 62339!----QUIT/NOSAVE----2025-01-23T10:15:16.803-03:00 The Conquist.image priorSource: 62425!----QUIT/NOSAVE----2025-01-23T10:15:16.824-03:00 The Conquist.image priorSource: 62425!----QUIT/NOSAVE----2025-01-23T15:32:10.403-03:00 The Conquist.image priorSource: 62425!----QUIT/NOSAVE----2025-01-23T15:32:10.433-03:00 The Conquist.image priorSource: 62425!----QUIT/NOSAVE----2025-01-23T15:47:18.282-03:00 The Conquist.image priorSource: 62425!!Juego methodsFor: 'as yet unclassified' stamp: '1/23/2025 15:47' prior: 81733!dibujarFondo    | imagen  boton1 boton2 |        "Cargar la imagen de fondo"    imagen := Form fromFileNamed: FileSystem workingDirectory / 'assets/backgrounds/background.png'.        "Crear ImageMorph para la imagen de fondo"    imagenMorph := ImageMorph new.    imagenMorph image: imagen.    imagenMorph position: 0@0. "Asegurarse de que la imagen de fondo esté en la esquina superior izquierda"        "Crear el botón 1"    boton1 := SimpleButtonMorph new.    boton1 label: 'Nuevo Juego'. "Definir el texto del botón"    boton1 target: self. "Definir el objetivo de la acción como la instancia actual"    boton1 actionSelector: #obtenerCantJugadores. "Definir el método a llamar cuando se presiona el botón"    boton1 extent: 150@50.    "Posicionar el botón 1 en el centro de la imagen"    boton1 position: (imagenMorph width // 2 - (boton1 width // 2)) - 120 @ (imagenMorph height // 2 - (boton1 height // 2)) + 120.    "Crear el botón 2"    boton2 := SimpleButtonMorph new.    boton2 label: 'Salir'. "Definir el texto del botón"    boton2 target: self. "Definir el objetivo de la acción como la instancia actual"    boton2 actionSelector: #eliminarMorphs. "Definir el método a llamar cuando se presiona el botón"    boton2 extent: 150@50.    "Posicionar el botón 2 debajo del botón 1"    boton2 position: (imagenMorph width // 2 - (boton2 width // 2)) -220 @ (imagenMorph height // 2 - (boton2 height // 2)) + 220.        "Agregar los botones al ImageMorph"    imagenMorph addMorph: boton1.    imagenMorph addMorph: boton2.        "Abrir el ImageMorph en el mundo"    imagenMorph openInWorld.! !!Juego methodsFor: 'as yet unclassified' stamp: '1/23/2025 15:48' prior: 126075!dibujarFondo    | imagen  boton1 boton2 |        "Cargar la imagen de fondo"    imagen := Form fromFileNamed: FileSystem workingDirectory / 'assets/backgrounds/background.png'.        "Crear ImageMorph para la imagen de fondo"    imagenMorph := ImageMorph new.    imagenMorph image: imagen.    imagenMorph position: 0@0. "Asegurarse de que la imagen de fondo esté en la esquina superior izquierda"        "Crear el botón 1"    boton1 := SimpleButtonMorph new.    boton1 label: 'Nuevo Juego'. "Definir el texto del botón"    boton1 target: self. "Definir el objetivo de la acción como la instancia actual"    boton1 actionSelector: #obtenerCantJugadores. "Definir el método a llamar cuando se presiona el botón"    boton1 extent: 150@50.    "Posicionar el botón 1 en el centro de la imagen"    boton1 position: (imagenMorph width // 2 - (boton1 width // 2)) - 120 @ (imagenMorph height // 2 - (boton1 height // 2)) + 120.    "Crear el botón 2"    boton2 := SimpleButtonMorph new.    boton2 label: 'Salir'. "Definir el texto del botón"    boton2 target: self. "Definir el objetivo de la acción como la instancia actual"    boton2 actionSelector: #eliminarMorphs. "Definir el método a llamar cuando se presiona el botón"    boton2 extent: 150@50.    "Posicionar el botón 2 debajo del botón 1"    boton2 position: (imagenMorph width // 2 - (boton2 width // 2)) -220 @ (imagenMorph height // 2 - (boton2 height // 2)) + 220.        "Agregar los botones al ImageMorph"    imagenMorph addMorph: boton1.    imagenMorph addMorph: boton2.        "Abrir el ImageMorph en el mundo"    imagenMorph openInExternalWindow.! !!Juego methodsFor: 'as yet unclassified' stamp: '1/23/2025 15:48' prior: 85077!eliminarMorphs    self currentWorld delete. "Cierra la ventana actual"! !!Juego methodsFor: 'as yet unclassified' stamp: '1/23/2025 15:52' prior: 133019!eliminarMorphsWorld submorphs "Selecciona a todos los submorphs y descide si es un ImageMorph para eliminarlo"        select: [ :morph | morph isKindOf: ImageMorph ]        thenDo: [ :morph | morph delete ].    self currentWorld delete. "Cierra la ventana actual"! !----QUIT/NOSAVE----2025-01-23T15:52:24.465-03:00 The Conquist.image priorSource: 62425!----QUIT/NOSAVE----2025-01-23T15:52:24.485-03:00 The Conquist.image priorSource: 62425!!Juego methodsFor: 'as yet unclassified' stamp: '1/23/2025 15:53' prior: 81733!dibujarFondo    | imagen  boton1 boton2 |        "Cargar la imagen de fondo"    imagen := Form fromFileNamed: FileSystem workingDirectory / 'assets/backgrounds/background.png'.        "Crear ImageMorph para la imagen de fondo"    imagenMorph := ImageMorph new.    imagenMorph image: imagen.    imagenMorph position: 0@0. "Asegurarse de que la imagen de fondo esté en la esquina superior izquierda"        "Crear el botón 1"    boton1 := SimpleButtonMorph new.    boton1 label: 'Nuevo Juego'. "Definir el texto del botón"    boton1 target: self. "Definir el objetivo de la acción como la instancia actual"    boton1 actionSelector: #obtenerCantJugadores. "Definir el método a llamar cuando se presiona el botón"        "Posicionar el botón 1 en el centro de la imagen"    boton1 position: (imagenMorph width // 2 - (boton1 width // 2)) @ (imagenMorph height // 2 - (boton1 height // 2) - 30).    "Crear el botón 2"    boton2 := SimpleButtonMorph new.    boton2 label: 'Salir'. "Definir el texto del botón"    boton2 target: self. "Definir el objetivo de la acción como la instancia actual"    boton2 actionSelector: #eliminarMorphs. "Definir el método a llamar cuando se p