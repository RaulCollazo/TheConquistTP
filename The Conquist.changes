----QUIT----2025-01-14T19:59:47.164227+01:00 Pharo12.0-SNAPSHOT-64bit-0384a4d925.image priorSource: 0!----QUIT----2025-01-14T19:59:47.164878+01:00 Pharo12.0-SNAPSHOT-64bit-0384a4d925.image priorSource: 0!----QUIT----2025-01-14T20:00:07.557219+01:00 Pharo12.0-SNAPSHOT-64bit-0384a4d925.image priorSource: 104!----QUIT----2025-01-14T20:00:07.55798+01:00 Pharo12.0-SNAPSHOT-64bit-0384a4d925.image priorSource: 208!!Casilla methodsFor: 'as yet unclassified' stamp: '1/21/2025 16:53'!crearCasilla: x and: y    "Crear un Morph cuadrado y almacenarlo en la variable de instancia"    morph := Morph new.    morph color: Color blue.    morph extent: 100@100. "Tamaño del cuadrado (100x100 píxeles)"    morph position: x@y. "Posicionar el morph según las coordenadas pasadas"    World addMorph: morph.! !!Casilla methodsFor: 'as yet unclassified' stamp: '1/21/2025 16:54'!eliminarCasilla    "Eliminar el Morph del mundo si existe"    morph ifNotNil: [        morph delete.        morph := nil.    ].! !!Juego methodsFor: 'as yet unclassified' stamp: '1/21/2025 16:55'!eliminarMorphsWorld submorphs do: [ :each |    (each class = Morph) ifTrue: [ each delete ].]! !!Juego methodsFor: 'as yet unclassified' stamp: '1/21/2025 19:39'!iniciar    | flag|self crearPantalla.    flag := false.    "Solicitar la cantidad de NPCs"    [ flag not ] whileTrue: [        CantNPC := (UIManager default request: '¿Cuántos participantes hay?') asNumber.        ((CantNPC sqrt \\ 2) = 0)            ifTrue: [ flag := true ]            ifFalse: [ UIManager default inform: 'Valor inválido' ].    ].    "Solicitar la cantidad de jugadores humanos"    CantJugadores := (UIManager default request: '¿Cuántos participantes humanos habrá?') asNumber.! !!Juego methodsFor: 'as yet unclassified' stamp: '1/21/2025 19:38'!dibujarPantalla! !!Juego methodsFor: 'as yet unclassified' stamp: '1/21/2025 21:24'!dibujarFondo|imagen imagenMorph|imagen := Form fromFileNamed: FileSystem workingDirectory , '/assets/backgrounds/background.png'.imagenMorph := ImageMorph new.imagenMorph image: imagen.imagenMorph openInWorld.! !!Juego methodsFor: 'accessing' stamp: '1/21/2025 19:35'!cantNPC	^ CantNPC! !!Juego methodsFor: 'accessing' stamp: '1/21/2025 19:35'!cantNPC: anObject	CantNPC := anObject! !!Juego methodsFor: 'accessing' stamp: '1/21/2025 19:35'!cantJugadores	^ CantJugadores! !!Juego methodsFor: 'accessing' stamp: '1/21/2025 19:35'!cantJugadores: anObject	CantJugadores := anObject! !!Juego methodsFor: 'accessing' stamp: '1/21/2025 19:35'!pantallaActual	^ PantallaActual! !!Juego methodsFor: 'accessing' stamp: '1/21/2025 19:35'!pantallaActual: anObject	PantallaActual := anObject! !!Juego methodsFor: 'initialization' stamp: '1/21/2025 19:36'!initializePantallaActual := 0.! !----End fileIn----!----SNAPSHOT----2025-01-21T21:36:08.858-03:00 The Conquist.image priorSource: 314!----SNAPSHOT----2025-01-21T21:36:08.875-03:00 The Conquist.image priorSource: 2853!Object << #Juego	slots: { #CantNPC . #CantJugadores . #PantallaActual. #imagenMorph };	package: 'TheConquist'!!Juego methodsFor: 'accessing' stamp: '1/21/2025 21:41'!imagenMorph	^ imagenMorph! !!Juego methodsFor: 'accessing' stamp: '1/21/2025 21:41'!imagenMorph: anObject	imagenMorph := anObject! !!Juego methodsFor: 'as yet unclassified' stamp: '1/21/2025 21:41' prior: 3853!dibujarFondo|imagen|imagen := Form fromFileNamed: FileSystem workingDirectory , '/assets/backgrounds/background.png'.imagenMorph := ImageMorph new.imagenMorph image: imagen.imagenMorph openInWorld.! !----SNAPSHOT----2025-01-21T21:43:15.525-03:00 The Conquist.image priorSource: 2937!----SNAPSHOT----2025-01-21T21:43:15.548-03:00 The Conquist.image priorSource: 3617!----SNAPSHOT----2025-01-21T21:46:14.363-03:00 The Conquist.image priorSource: 3702!----SNAPSHOT----2025-01-21T21:46:14.4-03:00 The Conquist.image priorSource: 3787!!Juego methodsFor: 'as yet unclassified' stamp: '1/21