Morph new.    labelMorph contents: label.    self tema: label.    labelMorph position: (buttonMorph bounds center - (labelMorph extent / 2)).        "Agregar la etiqueta al botón"    buttonMorph addMorph: labelMorph.        self morph: buttonMorph.! !!Casilla methodsFor: 'as yet unclassified' stamp: '2/9/2025 00:33' prior: 1250339!crearCasilla: x and: y label: label|buttonMorph labelMorph|buttonMorph := Morph new.buttonMorph bounds: (25@25 extent: 125@125).buttonMorph color: Color random.buttonMorph borderWidth: 2.buttonMorph borderColor: Color black.buttonMorph on: #mouseUp send: #botonClickeado to: TableroLogico.labelMorph := StringMorph new.labelMorph contents: label.self tema: label.labelMorph position: (buttonMorph bounds center - (labelMorph extent / 2))."Agregar la etiqueta al botón"buttonMorph addMorph: labelMorph.self morph: buttonMorph.! !!TableroLogico class methodsFor: 'as yet unclassified' stamp: '2/9/2025 00:39' prior: 1124669!crearMatrizMorphs: cantMorphs| matrizMorphs filas columnas fila columna morphcasilla|morphcasilla := Casilla new.filas := cantMorphs sqrt truncated.columnas := cantMorphs sqrt truncated.matrizMorphs := Matrix rows: filas columns: columnas.fila := 1.columna := 1.1 to: cantMorphs do: [:i |	morphcasilla crearCasilla: fila and: columna  label: (self matrizDeTemas at: fila column: columna).    matrizMorphs at: fila column: columna put: (morphcasilla).    columna := columna + 1.    (columna > columnas) ifTrue: [        columna := 1.        fila := fila + 1.    ].].self matrizDeMorphs: matrizMorphs.! !!TableroLogico class methodsFor: 'as yet unclassified' stamp: '2/9/2025 00:39' prior: 842703!dibujarTablero: imagenMorph cantNPC: cantNPC| temaCasilla fila columna |fila := 1.columna := 1.1 to: cantNPC do: [:i |    temaCasilla := (TableroLogico matrizDeMorphs at: fila column: columna) morph.    imagenMorph addMorph: temaCasilla.    temaCasilla position: (columna * 120) @ (fila * 120). "Ajusta la posición según sea necesario"    fila := fila + 1.    (fila > (cantNPC sqrt) ceiling) ifTrue: [        fila := 1.        columna := columna + 1.    ].]! !!TableroLogico class methodsFor: 'as yet unclassified' stamp: '2/9/2025 00:40' prior: 812869!dibujarTablero: imagenMorph|Casilla fila columna|fila := 0.columna := 1.1 to: (Juego cantNPC) do:[:i|	fila := fila + 1.	Casilla := (TableroLogico matrizDeMorphs at: fila column: columna) morph.	(fila = (Juego cantNPC sqrt)) ifTrue: [fila := 1. columna := columna + 1].	imagenMorph addMorph: Casilla.	Casilla position: (10*i)@(10*i).	]! !!TableroLogico class methodsFor: 'as yet unclassified' stamp: '2/9/2025 00:41' prior: 1255709!dibujarTablero: imagenMorph|Casilla fila columna|fila := 0.columna := 1.1 to: (Juego cantNPC) do:[:i|	fila := fila + 1.	Casilla := ((TableroLogico matrizDeMorphs at: fila column: columna) morph).	(fila = (Juego cantNPC sqrt)) ifTrue: [fila := 1. columna := columna + 1].	imagenMorph addMorph: Casilla.	Casilla position: (10*i)@(10*i).	]! !!TableroLogico class methodsFor: 'as yet unclassified' stamp: '2/9/2025 00:43' prior: 812039!dibujarTablero|Casilla fila columna|fila := 0.columna := 1.1 to: (Juego cantNPC) do:[:i|	fila := fila + 1.	Casilla := (TableroLogico matrizDeMorphs at: fila column: columna) morph.	(fila = (Juego cantNPC sqrt)) ifTrue: [fila := 1. columna := columna + 1].	Juego imagenMorph addMorph: Casilla.	Casilla position: (10*i)@(10*i).	]! !----QUIT/NOSAVE----2025-02-09T00:44:01.999-03:00 The Conquist.image priorSource: 612783!----QUIT/NOSAVE----2025-02-09T00:44:02.024-03:00 The Conquist.image priorSource: 612783!!TableroLogico class methodsFor: 'as yet unclassified' stamp: '2/9/2025 00:45' prior: 1124669!crearMatrizMorphs: cantMorphs| matrizMorphs filas columnas fila columna morphcasilla|morphcasilla := Casilla new.filas := cantMorphs sqrt truncated.columnas := cantMorphs sqrt truncated.matrizMorphs := Matrix rows: filas colum