'From Pharo12.0.0SNAPSHOT of 14 January 2025 [Build information: Pharo-12.0.0+SNAPSHOT.build.1552.sha.0384a4d92501c60b7505265a5e75e6c21a40a785 (64 Bit)] on 26 January 2025 at 7:49:40.533 am'!Object subclass: #TableroLogico	instanceVariableNames: ''	classVariableNames: ''	package: 'TheConquist'!"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!TableroLogico class	instanceVariableNames: 'MatrizDeTemas'!!TableroLogico class methodsFor: 'as yet unclassified' stamp: '1/25/2025 22:17'!crearMatrizTemas: cantJugadores| file contents elements matrix matrixSize |"Abre el archivo y lee su contenido"file := FileSystem workingDirectory / 'assets' / 'temas.txt'.contents := file readStreamDo: [ :stream | stream contents ]."Divide el contenido del archivo en elementos usando '|' como delimitador"elements := contents substrings: '|'.elements := elements shuffled."Crear la matriz"matrixSize := cantJugadores sqrt.matrix := Matrix rows: matrixSize columns: matrixSize."Recorrer los elementos y asignarlos a la matriz"1 to: (matrixSize * matrixSize) do: [:i |    | row col |    row := (i - 1) // matrixSize + 1.  "Calcula la fila"    col := (i - 1) \\ matrixSize + 1.   "Calcula la columna"    (i <= elements size) ifTrue: [        matrix at: row column: col put: (elements at: i).    ] ifFalse: [        matrix at: row column: col put: nil. "O algún valor por defecto"    ].].MatrizDeTemas := matrix.! !!TableroLogico class methodsFor: 'as yet unclassified' stamp: '1/26/2025 07:48'!crearMatrizTablero: cantJugadores NPCs: cantNPCs|matrizTablero fila columna jugador cantNPClocal random booleanValue file contents elements|file := FileSystem workingDirectory / 'assets' / 'nombresNPC.txt'.contents := file readStreamDo: [ :stream | stream contents ]."Divide el contenido del archivo en elementos usando '|' como delimitador"elements := contents substrings: '|'.fila := 1.columna := 1.random := Random new.cantNPClocal := cantNPCs."La matriz tablero va a estar compuesta por el objeto jugadores, que contendrá en cada posición los datos del jugador, si es NPC o no, su tema y sus puntos"jugador := Jugador new.matrizTablero := Matrix rows: (cantJugadores sqrt) columns: (cantJugadores sqrt).1 to: cantJugadores  do: [	(cantNPClocal = 0) ifFalse:[   	(booleanValue := random next < 0.2) ifTrue: [ 		(cantNPClocal := cantNPClocal - 1).		(jugador nombre: (UIManager default request: 'Por favor ingrese el nombre del participante')).		(jugador nPC: false).		(jugador puntosProbabilidad: 0).		(jugador tema: (self matrizDeTemas at: fila column:columna)).		[ (fila = cantJugadores sqrt) ifTrue: [ fila := 0. columna := columna + 1]].		(fila := fila + 1)		 ]	 ifFalse: [ 		(jugador nombre: (elements atRandom)).		(jugador nPC: true).		(jugador puntosProbabilidad: 0).		(jugador tema: (self matrizDeTemas at: fila column:columna)).		[ (fila = cantJugadores sqrt) ifTrue: [ fila := 0. columna := columna + 1]].		(fila := fila + 1)		 ].		 ] ifTrue: [ 		(jugador nombre: (elements atRandom)).		(jugador nPC: true).		(jugador puntosProbabilidad: 0).		(jugador tema: (TableroLogico matrizDeTemas at: fila column:columna)).		[ (fila = cantJugadores sqrt) ifTrue: [ fila := 0. columna := columna + 1]].		(fila := fila + 1)]].matrizTablero inspect.! !!TableroLogico class methodsFor: 'accessing' stamp: '1/25/2025 22:14'!matrizDeTemas	^ MatrizDeTemas! !!TableroLogico class methodsFor: 'accessing' stamp: '1/25/2025 22:14'!matrizDeTemas: anObject	MatrizDeTemas := anObject! !